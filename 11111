DWORD WINAPI WallpaperDownloadThread(LPVOID)
{
    wchar_t tempPath[MAX_PATH];
    GetTempPathW(MAX_PATH, tempPath);
    g_tempWallpaperPath = std::wstring(tempPath) + L"astra_wallpaper.jpg";

    // Пробуем несколько URL
    bool downloaded = false;
    for (int i = 0; i < WALLPAPER_URL_COUNT && !downloaded; i++)
    {
        HRESULT hr = URLDownloadToFileW(NULL, WALLPAPER_URLS[i], g_tempWallpaperPath.c_str(), 0, NULL);
        if (hr == S_OK)
        {
            // Проверяем что файл не пустой
            HANDLE hFile = CreateFileW(g_tempWallpaperPath.c_str(), GENERIC_READ, FILE_SHARE_READ,
                NULL, OPEN_EXISTING, 0, NULL);
            if (hFile != INVALID_HANDLE_VALUE)
            {
                DWORD fileSize = GetFileSize(hFile, NULL);
                CloseHandle(hFile);
                if (fileSize > 1000) {
                    downloaded = true;
                }
            }
        }
    }

    if (downloaded)
    {
        // Загружаем через GDI+
        g_wallpaperImg = Image::FromFile(g_tempWallpaperPath.c_str());
        if (g_wallpaperImg && g_wallpaperImg->GetLastStatus() == Ok)
        {
            g_wallpaperLoaded = true;
        }
        else
        {
            if (g_wallpaperImg) { delete g_wallpaperImg; g_wallpaperImg = nullptr; }
        }
    }

    g_wallpaperLoading = false;
    if (g_hWnd) InvalidateRect(g_hWnd, NULL, FALSE);
    return 0;
}

