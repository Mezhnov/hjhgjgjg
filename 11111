void UpdateDateTime()
{
    SYSTEMTIME st;
    GetLocalTime(&st);

    // Время
    wchar_t buf[64];
    swprintf_s(buf, L"%02d:%02d", st.wHour, st.wMinute);
    g_timeStr = buf;

    // Короткая дата
    swprintf_s(buf, L"%02d.%02d.%04d", st.wDay, st.wMonth, st.wYear);
    g_shortDateStr = buf;

    // Полная дата
    const wchar_t* months[] = {
        L"января", L"февраля", L"марта", L"апреля", L"мая", L"июня",
        L"июля", L"августа", L"сентября", L"октября", L"ноября", L"декабря"
    };
    const wchar_t* days[] = {
        L"Воскресенье", L"Понедельник", L"Вторник", L"Среда",
        L"Четверг", L"Пятница", L"Суббота"
    };

    swprintf_s(buf, L"%d %s %d г.", st.wDay, months[st.wMonth - 1], st.wYear);
    g_dateStr = buf;
    g_dayStr = days[st.wDayOfWeek];
}

