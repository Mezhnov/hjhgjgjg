// ==================== СИСТЕМНЫЕ ФУНКЦИИ ====================
void UpdateDateTime()
{
    SYSTEMTIME st;
    GetLocalTime(&st);

    // Время
    std::wstringstream ssTime;
    ssTime << std::setfill(L'0') << std::setw(2) << st.wHour << L":"
        << std::setfill(L'0') << std::setw(2) << st.wMinute;
    g_sCurrentTime = ssTime.str();

    // Дата
    std::wstringstream ssDate;
    ssDate << std::setfill(L'0') << std::setw(2) << st.wDay << L"."
        << std::setfill(L'0') << std::setw(2) << st.wMonth << L"."
        << st.wYear;
    g_sCurrentDate = ssDate.str();

    // День недели
    const wchar_t* days[] = { L"Воскресенье", L"Понедельник", L"Вторник", L"Среда",
                              L"Четверг", L"Пятница", L"Суббота" };
    g_sCurrentDay = days[st.wDayOfWeek];

    // Обновляем отображение
    if (g_hWndClock) SetWindowTextW(g_hWndClock, g_sCurrentTime.c_str());
    if (g_hWndDate)
    {
        std::wstring sDateFull = g_sCurrentDate + L", " + g_sCurrentDay;
        SetWindowTextW(g_hWndDate, sDateFull.c_str());
    }
}

// ==================== ЗАГРУЗКА ОБОЕВ ====================
class ImageDownloader
{
public:
    static DWORD WINAPI DownloadThreadProc(LPVOID lpParam)
    {
        // ✅ ИСПРАВЛЕНО: Получаем временную папку Windows
        wchar_t tempPath[MAX_PATH];
        GetTempPathW(MAX_PATH, tempPath);
        g_sTempImagePath = std::wstring(tempPath) + L"myos_wallpaper.jpg";

        // ✅ ИСПРАВЛЕНО: Загрузка с проверкой ошибки
        HRESULT hr = URLDownloadToFileW(NULL, WALLPAPER_URL, g_sTempImagePath.c_str(), 0, NULL);

        if (hr != S_OK)
        {
            // Загрузка не удалась - используем градиент
            g_bWallpaperLoaded = false;
            if (g_hWndMain) InvalidateRect(g_hWndMain, NULL, TRUE);
            return 0;
        }

        // Инициализируем GDI+
        Gdiplus::GdiplusStartupInput gdiplusStartupInput;
        ULONG_PTR gdiplusToken;
        Gdiplus::GdiplusStartup(&gdiplusToken, &gdiplusStartupInput, NULL);

        // ✅ ИСПРАВЛЕНО: Загружаем изображение с проверкой
        Gdiplus::Bitmap* bitmap = Gdiplus::Bitmap::FromFile(g_sTempImagePath.c_str());
        if (bitmap && bitmap->GetLastStatus() == Gdiplus::Ok)
        {
            HBITMAP hTempBitmap = NULL;
            // ✅ ИСПРАВЛЕНО: Используем белый фон вместо прозрачного
            bitmap->GetHBITMAP(Gdiplus::Color(255, 255, 255, 255), &hTempBitmap);

            if (hTempBitmap)
            {
                if (g_hbmWallpaper) DeleteObject(g_hbmWallpaper);
                g_hbmWallpaper = hTempBitmap;
                g_bWallpaperLoaded = true;

                if (g_hWndMain) InvalidateRect(g_hWndMain, NULL, TRUE);
            }
        }

        delete bitmap;
        Gdiplus::GdiplusShutdown(gdiplusToken);
        return 0;
    }
};

// ==================== МЕНЮ ПУСК ====================
void CreateStartMenu(HWND hWndParent, HINSTANCE hInst)
{
    g_hWndStartMenu = CreateWindowExW(
        WS_EX_TOPMOST | WS_EX_LAYERED,
        L"STATIC",
        L"",
        WS_CHILD | WS_VISIBLE | WS_BORDER,
        0, 0, START_MENU_WIDTH, START_MENU_HEIGHT,
        hWndParent, NULL, hInst, NULL
    );
}

void ToggleStartMenu()
{
    if (g_hWndStartMenu)
    {
        g_bStartMenuOpen = !g_bStartMenuOpen;
        ShowWindow(g_hWndStartMenu, g_bStartMenuOpen ? SW_SHOW : SW_HIDE);

        // Анимация появления
        if (g_bStartMenuOpen)
        {
            for (int i = 0; i <= 255; i += 25)
            {
                SetLayeredWindowAttributes(g_hWndStartMenu, 0, (BYTE)i, LWA_ALPHA);
                Sleep(10);
            }
        }

        SetFocus(g_hWndMain);
        InvalidateRect(g_hWndStartMenu, NULL, TRUE);
    }
}

void CloseStartMenu()
{
    if (g_bStartMenuOpen && g_hWndStartMenu)
    {
        // Анимация исчезновения
        for (int i = 255; i >= 0; i -= 25)
        {
            SetLayeredWindowAttributes(g_hWndStartMenu, 0, (BYTE)i, LWA_ALPHA);
            Sleep(10);
        }

        g_bStartMenuOpen = false;
        ShowWindow(g_hWndStartMenu, SW_HIDE);
        SetLayeredWindowAttributes(g_hWndStartMenu, 0, 255, LWA_ALPHA);
    }
}

// ==================== WNDPROC МЕНЮ ПУСК ====================
LRESULT CALLBACK StartMenuProc(HWND hWnd, UINT message, WPARAM wParam, LPARAM lParam)
{
    switch (message)
    {
    case WM_PAINT:
    {
        PAINTSTRUCT ps;
        HDC hdc = BeginPaint(hWnd, &ps);
        RECT rc;
        GetClientRect(hWnd, &rc);

        // Градиентный фон меню
        TRIVERTEX vertex[2];
        GRADIENT_RECT gRect;
        vertex[0].x = 0; vertex[0].y = 0;
        vertex[0].Red = 0x2800; vertex[0].Green = 0x2800; vertex[0].Blue = 0x2800;
        vertex[1].x = rc.right; vertex[1].y = rc.bottom;
        vertex[1].Red = 0x1800; vertex[1].Green = 0x1800; vertex[1].Blue = 0x1800;
        gRect.UpperLeft = 0; gRect.LowerRight = 1;
        GradientFill(hdc, vertex, 2, &gRect, 1, GRADIENT_FILL_RECT_V);

        // Боковая панель (синяя)
        HBRUSH hBrushAccent = CreateSolidBrush(COLOR_ACCENT);
        RECT rcSide = { 0, 0, 5, rc.bottom };
        FillRect(hdc, &rcSide, hBrushAccent);
        DeleteObject(hBrushAccent);

        // Заголовок с именем пользователя
        HBRUSH hBrushHeader = CreateSolidBrush(RGB(40, 40, 40));
        RECT rcHeader = { 5, 0, rc.right, 80 };
        FillRect(hdc, &rcHeader, hBrushHeader);
        DeleteObject(hBrushHeader);

        // Иконка пользователя (круг)
        HBRUSH hBrushUser = CreateSolidBrush(COLOR_ACCENT);
        HPEN hPenNone = CreatePen(PS_NULL, 0, 0);
        SelectObject(hdc, hBrushUser);
        SelectObject(hdc, hPenNone);
        Ellipse(hdc, 20, 15, 60, 55);
        DeleteObject(hBrushUser);
        DeleteObject(hPenNone);

        // Текст пользователя
        SetBkMode(hdc, TRANSPARENT);
        SetTextColor(hdc, COLOR_TEXT_WHITE);

        if (!g_hFontMenuBold)
            g_hFontMenuBold = CreateFontW(16, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE,
                DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
                DEFAULT_QUALITY, DEFAULT_PITCH | FF_DONTCARE, L"Segoe UI");

        HFONT hOldFont = (HFONT)SelectObject(hdc, g_hFontMenuBold);
        TextOutW(hdc, 70, 25, L"Пользователь", 10);

        if (!g_hFontMenu)
            g_hFontMenu = CreateFontW(13, 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE,
                DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
                DEFAULT_QUALITY, DEFAULT_PITCH | FF_DONTCARE, L"Segoe UI");
        SelectObject(hdc, g_hFontMenu);
        SetTextColor(hdc, COLOR_TEXT_GRAY);
        TextOutW(hdc, 70, 50, L"admin@myastra.local", 19);
        SelectObject(hdc, hOldFont);

        // Линия разделитель
        HPEN hPen = CreatePen(PS_SOLID, 1, RGB(50, 50, 50));
        SelectObject(hdc, hPen);
        MoveToEx(hdc, 5, 80, NULL);
        LineTo(hdc, rc.right, 80);
        DeleteObject(hPen);

        // Пункты меню
        int yPos = 95;
        int itemHeight = 45;

        for (int i = 0; i < MENU_ITEM_COUNT; i++)
        {
            if (g_menuItems[i].isSeparator)
            {
                yPos += 15;
                HPEN hPenSep = CreatePen(PS_SOLID, 1, RGB(50, 50, 50));
                SelectObject(hdc, hPenSep);
                MoveToEx(hdc, 15, yPos - 5, NULL);
                LineTo(hdc, rc.right - 10, yPos - 5);
                DeleteObject(hPenSep);
                yPos += 10;
                continue;
            }

            RECT rcItem = { 10, yPos, rc.right - 10, yPos + itemHeight };

            // Подсветка при наведении
            if (i == g_iHoveredMenuItem)
            {
                HBRUSH hBrushHover = CreateSolidBrush(COLOR_MENU_ITEM_HOVER);
                FillRect(hdc, &rcItem, hBrushHover);
                DeleteObject(hBrushHover);
            }

            // Иконка
            SetTextColor(hdc, COLOR_TEXT_WHITE);
            SelectObject(hdc, g_hFontMenu);
            TextOutW(hdc, 20, yPos + 12, g_menuItems[i].icon, wcslen(g_menuItems[i].icon));

            // Текст
            TextOutW(hdc, 55, yPos + 14, g_menuItems[i].text, wcslen(g_menuItems[i].text));

            yPos += itemHeight;
        }

        // Кнопка завершения внизу
        RECT rcFooter = { 5, rc.bottom - 40, rc.right - 5, rc.bottom };
        HBRUSH hBrushFooter = CreateSolidBrush(RGB(40, 40, 40));
        FillRect(hdc, &rcFooter, hBrushFooter);
        DeleteObject(hBrushFooter);

        SetTextColor(hdc, COLOR_TEXT_WHITE);
        TextOutW(hdc, 20, rc.bottom - 32, L"🔌 Завершение работы", 24);

        EndPaint(hWnd, &ps);
    }
    break;

    case WM_MOUSEMOVE:
    {
        POINT pt;
        GetCursorPos(&pt);
        ScreenToClient(hWnd, &pt);

        int yPos = 95;
        int itemHeight = 45;
        int newHover = -1;

        for (int i = 0; i < MENU_ITEM_COUNT; i++)
        {
            if (g_menuItems[i].isSeparator) { yPos += 25; continue; }

            if (pt.y >= yPos && pt.y < yPos + itemHeight && pt.x >= 10 && pt.x <= 340)
            {
                newHover = i;
            }
            yPos += itemHeight;
        }

        if (newHover != g_iHoveredMenuItem)
        {
            g_iHoveredMenuItem = newHover;
            InvalidateRect(hWnd, NULL, TRUE);
        }
    }
    break;

    case WM_LBUTTONDOWN:
    {
        POINT pt;
        GetCursorPos(&pt);
        ScreenToClient(hWnd, &pt);

        int yPos = 95;
        int itemHeight = 45;

        for (int i = 0; i < MENU_ITEM_COUNT; i++)
        {
            if (g_menuItems[i].isSeparator) { yPos += 25; continue; }

            if (pt.y >= yPos && pt.y < yPos + itemHeight && pt.x >= 10 && pt.x <= 340)
            {
                // Обработка клика по пункту меню
                switch (g_menuItems[i].id)
                {
                case 210: // Завершение работы
                    if (MessageBoxW(g_hWndMain,
                        L"Вы действительно хотите завершить работу?",
                        L"Завершение работы", MB_YESNO | MB_ICONQUESTION) == IDYES)
                    {
                        PostQuitMessage(0);
                    }
                    break;
                case 207: // Параметры
                    MessageBoxW(g_hWndMain, L"Открытие параметров системы...", L"Параметры", MB_OK);
                    break;
                case 201: // Проводник
                    MessageBoxW(g_hWndMain, L"Открытие проводника...", L"Проводник", MB_OK);
                    break;
                default:
                    MessageBoxW(g_hWndMain, g_menuItems[i].text, L"Запуск", MB_OK);
                }
                CloseStartMenu();
                break;
            }
            yPos += itemHeight;
        }
    }
    break;

    case WM_MOUSELEAVE:
        g_iHoveredMenuItem = -1;
        InvalidateRect(hWnd, NULL, TRUE);
        break;

    case WM_DESTROY:
        PostQuitMessage(0);
        break;

    default:
        return DefWindowProc(hWnd, message, wParam, lParam);
    }
    return 0;
}

