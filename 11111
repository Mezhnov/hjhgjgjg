void DrawDesktop(Graphics& g, int w, int h)
{
    int desktopH = h - TASKBAR_HEIGHT;

    if (g_wallpaperLoaded && g_wallpaperImg)
    {
        // Масштабируем обои на весь экран
        g.DrawImage(g_wallpaperImg, 0, 0, w, desktopH);
    }
    else
    {
        // Красивый градиент как запасной фон (стиль Windows 11)
        LinearGradientBrush bgBrush(
            Point(0, 0), Point(w, desktopH),
            Colors::GradientTop, Colors::GradientBottom);
        g.FillRectangle(&bgBrush, 0, 0, w, desktopH);

        // Декоративные круги
        SolidBrush circleBrush(Color(15, 255, 255, 255));
        g.FillEllipse(&circleBrush, w / 2 - 300, desktopH / 2 - 300, 600, 600);
        SolidBrush circleBrush2(Color(10, 76, 194, 255));
        g.FillEllipse(&circleBrush2, w / 2 - 200, desktopH / 2 - 200, 400, 400);

        if (g_wallpaperLoading)
        {
            // Индикатор загрузки
            SolidBrush textBr(Color(150, 255, 255, 255));
            StringFormat sf;
            sf.SetAlignment(StringAlignmentCenter);
            sf.SetLineAlignment(StringAlignmentCenter);
            RectF rcLoad((REAL)(w / 2 - 150), (REAL)(desktopH / 2 - 20), 300, 40);
            g.DrawString(L"Загрузка обоев...", -1, g_fontMenu, rcLoad, &sf, &textBr);
        }
    }
}

