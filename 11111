#include <windows.h>
#include <gdiplus.h>
#include <stdio.h>

#pragma comment(lib, "gdiplus.lib")

using namespace Gdiplus;

Image* g_bg = nullptr;
int g_w = 0, g_h = 0;

void DrawRoundedRect(Graphics& g, SolidBrush* brush, Pen* pen, REAL x, REAL y, REAL width, REAL height, REAL radius)
{
    GraphicsPath path;
    path.AddArc(x, y, radius * 2, radius * 2, 180, 90);
    path.AddArc(x + width - radius * 2, y, radius * 2, radius * 2, 270, 90);
    path.AddArc(x + width - radius * 2, y + height - radius * 2, radius * 2, radius * 2, 0, 90);
    path.AddArc(x, y + height - radius * 2, radius * 2, radius * 2, 90, 90);
    path.CloseFigure();
    if (brush) g.FillPath(brush, &path);
    if (pen) g.DrawPath(pen, &path);
}

LRESULT CALLBACK WndProc(HWND hwnd, UINT msg, WPARAM wParam, LPARAM lParam)
{
    switch (msg)
    {
    case WM_PAINT:
    {
        PAINTSTRUCT ps;
        HDC hdc = BeginPaint(hwnd, &ps);
        Graphics g(hdc);

        // Фон на весь экран
        if (g_bg) g.DrawImage(g_bg, 0, 0, g_w, g_h);
        else {
            SolidBrush dark(Color(10, 15, 35));
            g.FillRectangle(&dark, 0, 0, g_w, g_h);
        }

        // ==================== НИЖНЯЯ ПАНЕЛЬ (рисованная кодом) ====================
        int tbH = 68;
        int tbY = g_h - tbH;

        // Тёмная полупрозрачная основа (как в Win11)
        SolidBrush tbBrush(Color(235, 32, 32, 32));
        g.FillRectangle(&tbBrush, 0, tbY, g_w, tbH);

        FontFamily ff(L"Segoe UI");
        SolidBrush white(Color(255, 255, 255));
        SolidBrush textBlack(Color(0, 0, 0));

        // 1. Кнопка Пуск (логотип Windows 11 — 4 квадратика)
        int startX = 12;
        int iconY = tbY + 10;
        int iconSz = 48;
        SolidBrush logo(Color(255, 255, 255));
        int sq = 11;
        g.FillRectangle(&logo, startX + 7,  iconY + 7,  sq, sq);
        g.FillRectangle(&logo, startX + 7 + sq + 4, iconY + 7, sq, sq);
        g.FillRectangle(&logo, startX + 7, iconY + 7 + sq + 4, sq, sq);
        g.FillRectangle(&logo, startX + 7 + sq + 4, iconY + 7 + sq + 4, sq, sq);

        // 2. Поисковая строка
        int searchX = 78;
        int searchW = 440;
        int searchH = 38;
        SolidBrush searchBg(Color(240, 255, 255, 255));
        Pen searchBorder(Color(80, 80, 80), 1.5f);
        DrawRoundedRect(g, &searchBg, &searchBorder, searchX, tbY + 14, searchW, searchH, 19);

        // Иконка лупы
        Font iconFont(&ff, 22, FontStyleRegular, UnitPixel);
        g.DrawString(L"🔍", -1, &iconFont, PointF(searchX + 12, tbY + 17), &textBlack);

        // Текст "Поиск"
        Font searchFont(&ff, 16, FontStyleRegular, UnitPixel);
        StringFormat sf;
        sf.SetAlignment(StringAlignmentCenter);
        sf.SetLineAlignment(StringAlignmentCenter);
        g.DrawString(L"Поиск", -1, &searchFont, RectF(searchX + 50, tbY + 14, searchW - 70, searchH), &sf, &textBlack);

        // 3. Закреплённые иконки приложений (слева)
        wchar_t* apps[] = { L"👥", L"📁", L"🌐", L"🛍️", L"📝", L"💻", L"📊" };
        Color appColors[] = { Color(138,43,226), Color(255,215,0), Color(0,120,215), 
                              Color(0,183,235), Color(0,120,215), Color(0,122,204), Color(138,43,226) };
        int appsX = searchX + searchW + 30;
        for (int i = 0; i < 7; i++)
        {
            int x = appsX + i * 58;
            SolidBrush iconBg(appColors[i]);
            g.FillRectangle(&iconBg, x, iconY, 42, 42);           // фон иконки
            Font appFont(&ff, 26, FontStyleRegular, UnitPixel);
            g.DrawString(apps[i], -1, &appFont, PointF(x + 8, iconY + 6), &white);
        }

        // 4. Системный трей справа
        int trayRight = g_w - 20;
        Font trayFont(&ff, 14, FontStyleRegular, UnitPixel);
        Font clockFont(&ff, 18, FontStyleBold, UnitPixel);
        Font dateFont(&ff, 11, FontStyleRegular, UnitPixel);

        // Стрелка скрытых иконок
        g.DrawString(L"▲", -1, &trayFont, PointF(trayRight - 340, tbY + 22), &white);

        // РУС
        SolidBrush rusBg(Color(255, 255, 255));
        g.FillRectangle(&rusBg, trayRight - 310, tbY + 18, 46, 32);
        g.DrawString(L"РУС", -1, &trayFont, PointF(trayRight - 305, tbY + 23), &textBlack);

        // Иконки трея
        g.DrawString(L"📶", -1, &iconFont, PointF(trayRight - 250, tbY + 18), &white);
        g.DrawString(L"🔊", -1, &iconFont, PointF(trayRight - 205, tbY + 18), &white);
        g.DrawString(L"🔋", -1, &iconFont, PointF(trayRight - 160, tbY + 18), &white);

        // Часы и дата (живые)
        SYSTEMTIME st;
        GetLocalTime(&st);
        wchar_t timeBuf[6], dateBuf[11];
        swprintf_s(timeBuf, L"%02d:%02d", st.wHour, st.wMinute);
        swprintf_s(dateBuf, L"%02d.%02d.%04d", st.wDay, st.wMonth, st.wYear);

        g.DrawString(timeBuf, -1, &clockFont, PointF(trayRight - 110, tbY + 10), &white);
        g.DrawString(dateBuf, -1, &dateFont, PointF(trayRight - 115, tbY + 38), &white);

        EndPaint(hwnd, &ps);
        return 0;
    }

    case WM_KEYDOWN:
        if (wParam == VK_ESCAPE) DestroyWindow(hwnd);
        return 0;

    case WM_DESTROY:
        delete g_bg;
        ShowWindow(FindWindow(L"Shell_TrayWnd", NULL), SW_SHOW); // возвращаем настоящую панель
        PostQuitMessage(0);
        return 0;
    }
    return DefWindowProc(hwnd, msg, wParam, lParam);
}

int WINAPI WinMain(HINSTANCE hInst, HINSTANCE, LPSTR, int)
{
    GdiplusStartupInput gsi;
    ULONG_PTR gdiToken;
    GdiplusStartup(&gdiToken, &gsi, NULL);

    g_w = GetSystemMetrics(SM_CXSCREEN);
    g_h = GetSystemMetrics(SM_CYSCREEN);

    g_bg = new Image(L"background.jpg");   // ← твоя фотка сюда

    // Прячем настоящую панель Windows
    HWND realTB = FindWindow(L"Shell_TrayWnd", NULL);
    if (realTB) ShowWindow(realTB, SW_HIDE);

    WNDCLASS wc = {};
    wc.lpfnWndProc = WndProc;
    wc.hInstance = hInst;
    wc.lpszClassName = L"FakeOS2026";
    wc.hCursor = LoadCursor(NULL, IDC_ARROW);
    RegisterClass(&wc);

    HWND hwnd = CreateWindowEx(WS_EX_TOPMOST, L"FakeOS2026", L"Grok OS 2026",
        WS_POPUP, 0, 0, g_w, g_h, NULL, NULL, hInst, NULL);

    ShowWindow(hwnd, SW_SHOWMAXIMIZED);
    UpdateWindow(hwnd);

    MSG msg;
    while (GetMessage(&msg, NULL, 0, 0))
    {
        TranslateMessage(&msg);
        DispatchMessage(&msg);
    }

    GdiplusShutdown(gdiToken);
    return 0;
}
