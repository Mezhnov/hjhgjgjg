void DrawTaskbar(Graphics& g, int w, int h)
{
    int ty = h - TASKBAR_HEIGHT;

    // Фон панели задач (полупрозрачный)
    SolidBrush taskbarBr(Colors::TaskbarBg);
    g.FillRectangle(&taskbarBr, 0, ty, w, TASKBAR_HEIGHT);

    // Верхняя линия
    Pen topLine(Color(80, 255, 255, 255), 1);
    g.DrawLine(&topLine, 0, ty, w, ty);

    // === ЦЕНТРИРОВАННЫЕ ИКОНКИ ПАНЕЛИ ЗАДАЧ (стиль Windows 11) ===
    const wchar_t* taskbarIcons[] = {
        L"🔍", L"📁", L"🌐", L"📧", L"🎵", L"📷", L"⬛"
    };
    const int iconCount = 7;
    const int iconBtnW = 46;
    int totalW = iconCount * iconBtnW;
    int startX = (w - totalW) / 2;

    StringFormat sfIcon;
    sfIcon.SetAlignment(StringAlignmentCenter);
    sfIcon.SetLineAlignment(StringAlignmentCenter);

    for (int i = 0; i < iconCount; i++)
    {
        int bx = startX + i * iconBtnW;
        RectF iconRect((REAL)bx, (REAL)(ty + 4), (REAL)iconBtnW, (REAL)(TASKBAR_HEIGHT - 8));

        // Первая иконка — кнопка Пуск (подсвечена если меню открыто)
        if (i == 0 && g_startMenuOpen)
        {
            SolidBrush activeBr(Color(60, 76, 194, 255));
            g.FillRectangle(&activeBr, bx + 2, ty + 4, iconBtnW - 4, TASKBAR_HEIGHT - 8);

            // Индикатор активности
            SolidBrush indBr(Colors::AccentLight);
            g.FillRectangle(&indBr, bx + 12, ty + TASKBAR_HEIGHT - 5, iconBtnW - 24, 3);
        }

        SolidBrush emBr(Colors::TextWhite);
        g.DrawString(taskbarIcons[i], -1, g_fontEmoji, iconRect, &sfIcon, &emBr);

        // Индикатор запущенного приложения (точка снизу)
        if (i >= 1 && i <= 3)
        {
            SolidBrush dotBr(Colors::TextGray);
            g.FillEllipse(&dotBr, bx + iconBtnW / 2 - 2, ty + TASKBAR_HEIGHT - 6, 4, 4);
        }
    }

    // === СИСТЕМНЫЙ ТРЕЙ (правая часть) ===
    g_trayButtons.clear();

    int trayX = w - 10;
    int trayY = ty + 2;
    int trayH = TASKBAR_HEIGHT - 4;

    // --- Часы и дата ---
    trayX -= 90;
    {
        TrayButton btn;
        btn.rect = { trayX, trayY, trayX + 90, trayY + trayH };
        btn.tooltip = L"Часы";
        btn.hovered = false;
        g_trayButtons.push_back(btn);

        if (g_hoveredTrayBtn == (int)g_trayButtons.size() - 1)
        {
            SolidBrush hovBr(Colors::TrayHover);
            g.FillRectangle(&hovBr, (REAL)trayX, (REAL)(trayY + 2), 88, (REAL)(trayH - 4));
        }

        SolidBrush timeBr(Colors::TextWhite);
        SolidBrush dateBr(Colors::TextGray);
        StringFormat sfRight;
        sfRight.SetAlignment(StringAlignmentCenter);

        RectF timeRect((REAL)trayX, (REAL)(trayY + 4), 88, 20);
        g.DrawString(g_timeStr.c_str(), -1, g_fontTime, timeRect, &sfRight, &timeBr);

        RectF dateRect((REAL)trayX, (REAL)(trayY + 22), 88, 18);
        g.DrawString(g_shortDateStr.c_str(), -1, g_fontDate, dateRect, &sfRight, &dateBr);
    }

    // --- Разделитель ---
    trayX -= 8;
    Pen sepPen(Colors::Separator, 1);
    g.DrawLine(&sepPen, trayX + 4, trayY + 8, trayX + 4, trayY + trayH - 8);

    // --- Громкость ---
    trayX -= TRAY_ICON_SIZE;
    {
        TrayButton btn;
        btn.rect = { trayX, trayY, trayX + TRAY_ICON_SIZE, trayY + trayH };
        btn.tooltip = L"Громкость";
        btn.hovered = false;
        g_trayButtons.push_back(btn);

        if (g_hoveredTrayBtn == (int)g_trayButtons.size() - 1)
        {
            SolidBrush hovBr(Colors::TrayHover);
            g.FillRectangle(&hovBr, (REAL)trayX + 2, (REAL)(trayY + 2),
                (REAL)(TRAY_ICON_SIZE - 4), (REAL)(trayH - 4));
        }

        // Иконка громкости
        SolidBrush volBr(Colors::TextWhite);
        std::wstring volIcon = g_volumeLevel > 50 ? L"🔊" : (g_volumeLevel > 0 ? L"🔉" : L"🔇");
        RectF volRect((REAL)trayX, (REAL)(trayY + 2), (REAL)TRAY_ICON_SIZE, (REAL)(trayH - 4));
        StringFormat sfC;
        sfC.SetAlignment(StringAlignmentCenter);
        sfC.SetLineAlignment(StringAlignmentCenter);
        g.DrawString(volIcon.c_str(), -1, g_fontEmoji, volRect, &sfC, &volBr);
    }

    // --- Wi-Fi ---
    trayX -= TRAY_ICON_SIZE;
    {
        TrayButton btn;
        btn.rect = { trayX, trayY, trayX + TRAY_ICON_SIZE, trayY + trayH };
        btn.tooltip = L"Сеть";
        btn.hovered = false;
        g_trayButtons.push_back(btn);

        if (g_hoveredTrayBtn == (int)g_trayButtons.size() - 1)
        {
            SolidBrush hovBr(Colors::TrayHover);
            g.FillRectangle(&hovBr, (REAL)trayX + 2, (REAL)(trayY + 2),
                (REAL)(TRAY_ICON_SIZE - 4), (REAL)(trayH - 4));
        }

        SolidBrush wifiBr(g_wifiConnected ? Colors::TextWhite : Color(255, 255, 80, 80));
        std::wstring wifiIcon = g_wifiConnected ? L"📶" : L"❌";
        RectF wifiRect((REAL)trayX, (REAL)(trayY + 2), (REAL)TRAY_ICON_SIZE, (REAL)(trayH - 4));
        g.DrawString(wifiIcon.c_str(), -1, g_fontEmoji, wifiRect, &sfIcon, &wifiBr);
    }

    // --- Батарея ---
    trayX -= 50;
    {
        TrayButton btn;
        btn.rect = { trayX, trayY, trayX + 50, trayY + trayH };
        btn.tooltip = L"Батарея";
        btn.hovered = false;
        g_trayButtons.push_back(btn);

        if (g_hoveredTrayBtn == (int)g_trayButtons.size() - 1)
        {
            SolidBrush hovBr(Colors::TrayHover);
            g.FillRectangle(&hovBr, (REAL)trayX + 2, (REAL)(trayY + 2), 46, (REAL)(trayH - 4));
        }

        // Рисуем батарею
        int bx = trayX + 8, by = trayY + 14;
        int bw = 24, bh = 14;
        Pen battPen(Colors::TextWhite, 1.5f);
        g.DrawRectangle(&battPen, bx, by, bw, bh);
        g.FillRectangle(&SolidBrush(Colors::TextWhite), bx + bw, by + 3, 3, bh - 6);

        // Уровень заряда
        Color battColor = g_batteryLevel > 50 ? Colors::BatteryGreen :
            (g_batteryLevel > 20 ? Colors::BatteryYellow : Colors::BatteryRed);
        int fillW = (int)((bw - 4) * g_batteryLevel / 100.0);
        SolidBrush fillBr(battColor);
        g.FillRectangle(&fillBr, bx + 2, by + 2, fillW, bh - 4);

        // Процент
        wchar_t battText[8];
        swprintf_s(battText, L"%d%%", g_batteryLevel);
        SolidBrush battTextBr(Colors::TextGray);
        RectF battTextRect((REAL)(trayX), (REAL)(trayY + 30), 50, 14);
        StringFormat sfBatt;
        sfBatt.SetAlignment(StringAlignmentCenter);
        g.DrawString(battText, -1, g_fontTray, battTextRect, &sfBatt, &battTextBr);
    }

    // --- Язык ---
    trayX -= 40;
    {
        TrayButton btn;
        btn.rect = { trayX, trayY, trayX + 40, trayY + trayH };
        btn.tooltip = L"Язык";
        btn.hovered = false;
        g_trayButtons.push_back(btn);

        if (g_hoveredTrayBtn == (int)g_trayButtons.size() - 1)
        {
            SolidBrush hovBr(Colors::TrayHover);
            g.FillRectangle(&hovBr, (REAL)trayX + 2, (REAL)(trayY + 2), 36, (REAL)(trayH - 4));
        }

        SolidBrush langBr(Colors::TextWhite);
        RectF langRect((REAL)trayX, (REAL)(trayY + 2), 40, (REAL)(trayH - 4));
        g.DrawString(g_langStr.c_str(), -1, g_fontTime, langRect, &sfIcon, &langBr);
    }

    // --- Левая часть: кнопка Пуск с логотипом ---
    // (уже нарисована в центре)
}

// ============================================================
//                    ОТРИСОВКА: МЕНЮ ПУСК
// ============================================================

void DrawStartMenu(Graphics& g, int w, int h)
{
    if (!g_startMenuOpen && g_startMenuAnimProgress <= 0) return;

    float progress = g_startMenuAnimProgress / 100.0f;
    if (progress <= 0) return;

    int menuX = (w - START_MENU_W) / 2;
    int menuY = h - TASKBAR_HEIGHT - (int)(START_MENU_H * progress);
    int menuH = (int)(START_MENU_H * progress);

    // Фон меню с закруглёнными углами
    GraphicsPath path;
    int radius = 12;
    path.AddArc(menuX, menuY, radius * 2, radius * 2, 180, 90);
    path.AddArc(menuX + START_MENU_W - radius * 2, menuY, radius * 2, radius * 2, 270, 90);
    path.AddLine(menuX + START_MENU_W, menuY + radius, menuX + START_MENU_W, menuY + menuH);
    path.AddLine(menuX + START_MENU_W, menuY + menuH, menuX, menuY + menuH);
    path.AddLine(menuX, menuY + menuH, menuX, menuY + radius);

    SolidBrush menuBg(Colors::StartMenuBg);
    g.FillPath(&menuBg, &path);

    // Рамка
    Pen borderPen(Color(60, 255, 255, 255), 1);
    g.DrawPath(&borderPen, &path);

    if (progress < 0.9f) return; // Не рисуем контент пока анимация не завершена

    // --- Поле поиска ---
    int searchX = menuX + 30;
    int searchY = menuY + 30;
    int searchW = START_MENU_W - 60;
    int searchH = 36;

    SolidBrush searchBg(Colors::StartMenuSearch);
    GraphicsPath searchPath;
    int sr = 18;
    searchPath.AddArc(searchX, searchY, sr * 2, sr * 2, 180, 90);
    searchPath.AddArc(searchX + searchW - sr * 2, searchY, sr * 2, sr * 2, 270, 90);
    searchPath.AddArc(searchX + searchW - sr * 2, searchY + searchH - sr * 2, sr * 2, sr * 2, 0, 90);
    searchPath.AddArc(searchX, searchY + searchH - sr * 2, sr * 2, sr * 2, 90, 90);
    g.FillPath(&searchBg, &searchPath);

    Pen searchBorder(Color(40, 255, 255, 255), 1);
    g.DrawPath(&searchBorder, &searchPath);

    // Иконка поиска и текст
    SolidBrush searchTextBr(Colors::TextDimGray);
    StringFormat sfLeft;
    sfLeft.SetAlignment(StringAlignmentNear);
    sfLeft.SetLineAlignment(StringAlignmentCenter);
    RectF searchTextRect((REAL)(searchX + 15), (REAL)searchY, (REAL)(searchW - 30), (REAL)searchH);
    g.DrawString(L"🔍  Введите запрос для поиска", -1, g_fontMenu, searchTextRect, &sfLeft, &searchTextBr);

    // --- Закреплённые приложения ---
    int secY = searchY + searchH + 25;

    SolidBrush titleBr(Colors::TextWhite);
    g.DrawString(L"Закреплённые", -1, g_fontMenuTitle,
        PointF((REAL)(menuX + 30), (REAL)secY), &titleBr);

    SolidBrush moreBr(Colors::TextGray);
    StringFormat sfRight;
    sfRight.SetAlignment(StringAlignmentFar);
    RectF moreRect((REAL)menuX, (REAL)secY, (REAL)(START_MENU_W - 30), 20);
    g.DrawString(L"Все приложения >", -1, g_fontMenuSmall, moreRect, &sfRight, &moreBr);

    secY += 30;

    int cols = 6;
    int cellW = (START_MENU_W - 60) / cols;
    int cellH = 75;

    StringFormat sfCenter;
    sfCenter.SetAlignment(StringAlignmentCenter);
    sfCenter.SetLineAlignment(StringAlignmentCenter);

    StringFormat sfCenterName;
    sfCenterName.SetAlignment(StringAlignmentCenter);
    sfCenterName.SetTrimming(StringTrimmingEllipsisWord);

    for (int i = 0; i < (int)g_pinnedApps.size() && i < 12; i++)
    {
        int col = i % cols;
        int row = i / cols;
        int cx = menuX + 30 + col * cellW;
        int cy = secY + row * cellH;

        // Hover эффект
        if (g_hoveredStartItem == i)
        {
            SolidBrush hovBr(Colors::StartMenuItemHover);
            GraphicsPath itemPath;
            int ir = 6;
            itemPath.AddArc(cx + 4, cy + 2, ir * 2, ir * 2, 180, 90);
            itemPath.AddArc(cx + cellW - 4 - ir * 2, cy + 2, ir * 2, ir * 2, 270, 90);
            itemPath.AddArc(cx + cellW - 4 - ir * 2, cy + cellH - 2 - ir * 2, ir * 2, ir * 2, 0, 90);
            itemPath.AddArc(cx + 4, cy + cellH - 2 - ir * 2, ir * 2, ir * 2, 90, 90);
            g.FillPath(&hovBr, &itemPath);
        }

        // Эмодзи
        SolidBrush emBr(Colors::TextWhite);
        RectF emRect((REAL)cx, (REAL)(cy + 5), (REAL)cellW, 40);
        g.DrawString(g_pinnedApps[i].emoji.c_str(), -1, g_fontEmojiLarge, emRect, &sfCenter, &emBr);

        // Название
        SolidBrush nameBr(Colors::TextGray);
        RectF nameRect((REAL)(cx + 2), (REAL)(cy + 48), (REAL)(cellW - 4), 22);
        g.DrawString(g_pinnedApps[i].name.c_str(), -1, g_fontMenuSmall, nameRect, &sfCenterName, &nameBr);
    }

    // --- Рекомендации ---
    secY += (((int)g_pinnedApps.size() + cols - 1) / cols) * cellH + 15;

    // Разделитель
    Pen sepPen(Colors::Separator, 1);
    g.DrawLine(&sepPen, menuX + 30, secY, menuX + START_MENU_W - 30, secY);

    secY += 15;

    g.DrawString(L"Рекомендации", -1, g_fontMenuTitle,
        PointF((REAL)(menuX + 30), (REAL)secY), &titleBr);
    secY += 30;

    for (int i = 0; i < (int)g_recommendedApps.size(); i++)
    {
        int ry = secY + i * 40;
        int rx = menuX + 30;

        // Hover
        int hoverIdx = 100 + i;
        if (g_hoveredStartItem == hoverIdx)
        {
            SolidBrush hovBr(Colors::StartMenuItemHover);
            g.FillRectangle(&hovBr, (REAL)rx, (REAL)ry, (REAL)(START_MENU_W - 60), 36);
        }

        SolidBrush emBr(Colors::TextWhite);
        g.DrawString(g_recommendedApps[i].emoji.c_str(), -1, g_fontEmoji,
            PointF((REAL)rx, (REAL)(ry + 4)), &emBr);

        SolidBrush nameBr(Colors::TextWhite);
        g.DrawString(g_recommendedApps[i].name.c_str(), -1, g_fontMenu,
            PointF((REAL)(rx + 40), (REAL)(ry + 8)), &nameBr);
    }

    // --- Нижняя панель: пользователь и выключение ---
    int footerY = menuY + menuH - 55;

    Pen footSep(Colors::Separator, 1);
    g.DrawLine(&footSep, menuX + 20, footerY, menuX + START_MENU_W - 20, footerY);

    footerY += 12;

    // Аватар пользователя (круг)
    SolidBrush avatarBr(Colors::AccentBlue);
    g.FillEllipse(&avatarBr, menuX + 30, footerY, 32, 32);
    SolidBrush avatarText(Colors::TextWhite);
    RectF avatarRect((REAL)(menuX + 30), (REAL)footerY, 32, 32);
    g.DrawString(L"A", -1, g_fontMenuTitle, avatarRect, &sfCenter, &avatarText);

    // Имя
    g.DrawString(L"Пользователь", -1, g_fontMenu,
        PointF((REAL)(menuX + 72), (REAL)(footerY + 7)), &titleBr);

    // Кнопка выключения
    SolidBrush powerBr(Colors::TextGray);
    g.DrawString(L"⏻", -1, g_fontEmoji,
        PointF((REAL)(menuX + START_MENU_W - 60), (REAL)(footerY + 2)), &powerBr);
}

// ============================================================
//                    ГЛАВНАЯ ОТРИСОВКА
// ============================================================

void OnPaint(HWND hWnd)
{
    PAINTSTRUCT ps;
    HDC hdc = BeginPaint(hWnd, &ps);

    // Двойная буферизация
    HDC hdcMem = CreateCompatibleDC(hdc);
    HBITMAP hbmMem = CreateCompatibleBitmap(hdc, g_screenW, g_screenH);
    HBITMAP hbmOld = (HBITMAP)SelectObject(hdcMem, hbmMem);

    {
        Graphics g(hdcMem);
        g.SetSmoothingMode(SmoothingModeAntiAlias);
        g.SetTextRenderingHint(TextRenderingHintClearTypeGridFit);

        InitFonts(g);

        // 1. Рабочий стол
        DrawDesktop(g, g_screenW, g_screenH);

        // 2. Иконки рабочего стола
        DrawDesktopIcons(g);

        // 3. Панель задач
        DrawTaskbar(g, g_screenW, g_screenH);

        // 4. Меню Пуск (поверх всего)
        DrawStartMenu(g, g_screenW, g_screenH);
    }

    BitBlt(hdc, 0, 0, g_screenW, g_screenH, hdcMem, 0, 0, SRCCOPY);

    SelectObject(hdcMem, hbmOld);
    DeleteObject(hbmMem);
    DeleteDC(hdcMem);

    EndPaint(hWnd, &ps);
}

// ============================================================
//                    ОБРАБОТКА МЫШИ
// ============================================================

int HitTestStartMenuItem(int mx, int my)
{
    if (!g_startMenuOpen) return -1;

    int menuX = (g_screenW - START_MENU_W) / 2;
    int menuY = g_screenH - TASKBAR_HEIGHT - START_MENU_H;
    int searchH = 36;
    int secY = menuY + 30 + searchH + 55;
    int cols = 6;
    int cellW = (START_MENU_W - 60) / cols;
    int cellH = 75;

    // Закреплённые
    for (int i = 0; i < (int)g_pinnedApps.size() && i < 12; i++)
    {
        int col = i % cols;
        int row = i / cols;
        int cx = menuX + 30 + col * cellW;
        int cy = secY + row * cellH;

        if (mx >= cx && mx < cx + cellW && my >= cy && my < cy + cellH)
            return i;
    }

    // Рекомендации
    int recY = secY + (((int)g_pinnedApps.size() + cols - 1) / cols) * cellH + 60;
    for (int i = 0; i < (int)g_recommendedApps.size(); i++)
    {
        int ry = recY + i * 40;
        if (mx >= menuX + 30 && mx < menuX + START_MENU_W - 30 &&
            my >= ry && my < ry + 36)
            return 100 + i;
    }

    return -1;
}

int HitTestDesktopIcon(int mx, int my)
{
    for (int i = 0; i < (int)g_desktopIcons.size(); i++)
    {
        auto& icon = g_desktopIcons[i];
        if (mx >= icon.x - 5 && mx < icon.x + DESKTOP_ICON_SIZE + 5 &&
            my >= icon.y - 5 && my < icon.y + DESKTOP_ICON_SIZE + 25)
            return i;
    }
    return -1;
}

int HitTestTrayButton(int mx, int my)
{
    for (int i = 0; i < (int)g_trayButtons.size(); i++)
    {
        RECT& r = g_trayButtons[i].rect;
        if (mx >= r.left && mx < r.right && my >= r.top && my < r.bottom)
            return i;
    }
    return -1;
}

bool IsInTaskbarCenter(int mx, int my)
{
    int ty = g_screenH - TASKBAR_HEIGHT;
    if (my < ty || my > g_screenH) return false;

    int iconBtnW = 46;
    int iconCount = 7;
    int totalW = iconCount * iconBtnW;
    int startX = (g_screenW - totalW) / 2;

    return mx >= startX && mx < startX + iconBtnW; // Только кнопка Пуск (первая)
}

// ============================================================
//                    WNDPROC
// ============================================================

LRESULT CALLBACK WndProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam)
{
    switch (msg)
    {
    case WM_CREATE:
    {
        g_screenW = GetSystemMetrics(SM_CXSCREEN);
        g_screenH = GetSystemMetrics(SM_CYSCREEN);

        InitDesktopIcons();
        InitStartMenu();
        UpdateDateTime();

        SetTimer(hWnd, TIMER_CLOCK, 1000, NULL);

        // Загрузка обоев в фоновом потоке
        CreateThread(NULL, 0, WallpaperDownloadThread, NULL, 0, NULL);
    }
    break;

    case WM_TIMER:
    {
        if (wParam == TIMER_CLOCK)
        {
            UpdateDateTime();
            InvalidateRect(hWnd, NULL, FALSE);
        }
        else if (wParam == TIMER_ANIM)
        {
            if (g_startMenuOpen && g_startMenuAnimProgress < 100)
            {
                g_startMenuAnimProgress += 12;
                if (g_startMenuAnimProgress > 100) g_startMenuAnimProgress = 100;
                InvalidateRect(hWnd, NULL, FALSE);
            }
            else if (!g_startMenuOpen && g_startMenuAnimProgress > 0)
            {
                g_startMenuAnimProgress -= 15;
                if (g_startMenuAnimProgress < 0) g_startMenuAnimProgress = 0;
                InvalidateRect(hWnd, NULL, FALSE);
            }

            if ((g_startMenuOpen && g_startMenuAnimProgress >= 100) ||
                (!g_startMenuOpen && g_startMenuAnimProgress <= 0))
            {
                KillTimer(hWnd, TIMER_ANIM);
            }
        }
    }
    break;

    case WM_PAINT:
        OnPaint(hWnd);
        return 0;

    case WM_ERASEBKGND:
        return 1;

    case WM_MOUSEMOVE:
    {
        int mx = LOWORD(lParam);
        int my = HIWORD(lParam);

        bool needRedraw = false;

        // Hover на иконках рабочего стола
        int newHoverIcon = HitTestDesktopIcon(mx, my);
        if (newHoverIcon != g_hoveredDesktopIcon) {
            g_hoveredDesktopIcon = newHoverIcon;
            needRedraw = true;
        }

        // Hover на пунктах меню Пуск
        int newHoverStart = HitTestStartMenuItem(mx, my);
        if (newHoverStart != g_hoveredStartItem) {
            g_hoveredStartItem = newHoverStart;
            needRedraw = true;
        }

        // Hover на кнопках трея
        int newHoverTray = HitTestTrayButton(mx, my);
        if (newHoverTray != g_hoveredTrayBtn) {
            g_hoveredTrayBtn = newHoverTray;
            needRedraw = true;
        }

        if (needRedraw) InvalidateRect(hWnd, NULL, FALSE);
    }
    break;

    case WM_LBUTTONDOWN:
    {
        int mx = LOWORD(lParam);
        int my = HIWORD(lParam);

        // Клик по кнопке Пуск
        if (IsInTaskbarCenter(mx, my))
        {
            g_startMenuOpen = !g_startMenuOpen;
            SetTimer(hWnd, TIMER_ANIM, 16, NULL);
            InvalidateRect(hWnd, NULL, FALSE);
            return 0;
        }

        // Клик по меню Пуск
        if (g_startMenuOpen)
        {
            int menuX = (g_screenW - START_MENU_W) / 2;
            int menuY = g_screenH - TASKBAR_HEIGHT - START_MENU_H;

            if (mx >= menuX && mx < menuX + START_MENU_W &&
                my >= menuY && my < menuY + START_MENU_H)
            {
                int item = HitTestStartMenuItem(mx, my);
                if (item >= 0 && item < 100)
                {
                    MessageBoxW(hWnd, g_pinnedApps[item].name.c_str(), L"Запуск приложения", MB_OK);
                    g_startMenuOpen = false;
                    SetTimer(hWnd, TIMER_ANIM, 16, NULL);
                }
                return 0;
            }
            else
            {
                // Клик вне меню — закрыть
                g_startMenuOpen = false;
                SetTimer(hWnd, TIMER_ANIM, 16, NULL);
                InvalidateRect(hWnd, NULL, FALSE);
            }
        }

        // Клик по иконке рабочего стола
        int clickedIcon = HitTestDesktopIcon(mx, my);
        g_selectedDesktopIcon = clickedIcon;
        InvalidateRect(hWnd, NULL, FALSE);

        // Клик по кнопкам трея
        int clickedTray = HitTestTrayButton(mx, my);
        if (clickedTray == 0) // Часы
        {
            std::wstring info = g_dayStr + L", " + g_dateStr + L"\n" + g_timeStr;
            MessageBoxW(hWnd, info.c_str(), L"Дата и время", MB_OK);
        }
        else if (clickedTray == 1) // Громкость
        {
            g_volumeLevel = (g_volumeLevel > 0) ? 0 : 65;
            InvalidateRect(hWnd, NULL, FALSE);
        }
        else if (clickedTray == 2) // Wi-Fi
        {
            g_wifiConnected = !g_wifiConnected;
            InvalidateRect(hWnd, NULL, FALSE);
        }
        else if (clickedTray == 4) // Язык
        {
            g_langStr = (g_langStr == L"RUS") ? L"ENG" : L"RUS";
            InvalidateRect(hWnd, NULL, FALSE);
        }
    }
    break;

    case WM_LBUTTONDBLCLK:
    {
        int mx = LOWORD(lParam);
        int my = HIWORD(lParam);

        int clickedIcon = HitTestDesktopIcon(mx, my);
        if (clickedIcon >= 0)
        {
            MessageBoxW(hWnd, g_desktopIcons[clickedIcon].name.c_str(),
                L"Открытие", MB_OK);
        }
    }
    break;

    case WM_KEYDOWN:
    {
        if (wParam == VK_ESCAPE)
        {
            if (g_startMenuOpen)
            {
                g_startMenuOpen = false;
                SetTimer(hWnd, TIMER_ANIM, 16, NULL);
            }
            else
            {
                if (MessageBoxW(hWnd, L"Выйти из системы?", L"MyAstra OS",
                    MB_YESNO | MB_ICONQUESTION) == IDYES)
                    PostQuitMessage(0);
            }
        }
        else if (wParam == VK_LWIN || wParam == VK_RWIN)
        {
            g_startMenuOpen = !g_startMenuOpen;
            SetTimer(hWnd, TIMER_ANIM, 16, NULL);
            InvalidateRect(hWnd, NULL, FALSE);
        }
    }
    break;

    case WM_DESTROY:
    {
        KillTimer(hWnd, TIMER_CLOCK);
        KillTimer(hWnd, TIMER_ANIM);

        delete g_wallpaperImg;
        delete g_fontTime; delete g_fontDate; delete g_fontTray;
        delete g_fontMenu; delete g_fontMenuTitle; delete g_fontMenuSmall;
        delete g_fontDesktopIcon; delete g_fontEmoji; delete g_fontEmojiLarge;
        delete g_fontFamily; delete g_fontFamilyEmoji;

        if (!g_tempWallpaperPath.empty())
            DeleteFileW(g_tempWallpaperPath.c_str());

        PostQuitMessage(0);
    }
    break;

    default:
        return DefWindowProcW(hWnd, msg, wParam, lParam);
    }
    return 0;
}

// ============================================================
//                    ТОЧКА ВХОДА
// ============================================================

int WINAPI WinMain(HINSTANCE hInstance, HINSTANCE, LPSTR, int)
{
    g_hInst = hInstance;

    // GDI+
    GdiplusStartupInput gdipInput;
    GdiplusStartup(&g_gdipToken, &gdipInput, NULL);
    CoInitialize(NULL);

    // Регистрация класса окна
    WNDCLASSEXW wc = {};
    wc.cbSize = sizeof(WNDCLASSEXW);
    wc.style = CS_HREDRAW | CS_VREDRAW | CS_DBLCLKS;
    wc.lpfnWndProc = WndProc;
    wc.hInstance = hInstance;
    wc.hCursor = LoadCursor(NULL, IDC_ARROW);
    wc.hbrBackground = (HBRUSH)GetStockObject(BLACK_BRUSH);
    wc.lpszClassName = L"MyAstraOS";
    RegisterClassExW(&wc);

    // Полноэкранное окно
    g_screenW = GetSystemMetrics(SM_CXSCREEN);
    g_screenH = GetSystemMetrics(SM_CYSCREEN);

    g_hWnd = CreateWindowExW(
        WS_EX_TOPMOST,
        L"MyAstraOS",
        L"MyAstra OS",
        WS_POPUP | WS_VISIBLE,
        0, 0, g_screenW, g_screenH,
        NULL, NULL, hInstance, NULL
    );

    ShowWindow(g_hWnd, SW_SHOWMAXIMIZED);
    UpdateWindow(g_hWnd);

    // Цикл сообщений
    MSG msg;
    while (GetMessageW(&msg, NULL, 0, 0))
    {
        TranslateMessage(&msg);
        DispatchMessageW(&msg);
    }

    GdiplusShutdown(g_gdipToken);
    CoUninitialize();

    return (int)msg.wParam;
}
