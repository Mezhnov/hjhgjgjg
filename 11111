void DrawDesktopIcons(Graphics& g)
{
    StringFormat sf;
    sf.SetAlignment(StringAlignmentCenter);
    sf.SetLineAlignment(StringAlignmentNear);
    sf.SetTrimming(StringTrimmingEllipsisWord);

    for (int i = 0; i < (int)g_desktopIcons.size(); i++)
    {
        auto& icon = g_desktopIcons[i];
        int ix = icon.x, iy = icon.y;

        // Фон при наведении/выделении
        if (icon.selected || i == g_selectedDesktopIcon)
        {
            SolidBrush selBr(Colors::DesktopIconSelect);
            g.FillRectangle(&selBr, ix - 5, iy - 5,
                DESKTOP_ICON_SIZE + 10, DESKTOP_ICON_SIZE + 30);
        }
        else if (i == g_hoveredDesktopIcon)
        {
            SolidBrush hovBr(Colors::DesktopIconHover);
            g.FillRectangle(&hovBr, ix - 5, iy - 5,
                DESKTOP_ICON_SIZE + 10, DESKTOP_ICON_SIZE + 30);
        }

        // Эмодзи-иконка
        SolidBrush emojiBr(Colors::TextWhite);
        RectF emojiRect((REAL)ix, (REAL)iy, (REAL)DESKTOP_ICON_SIZE, (REAL)(DESKTOP_ICON_SIZE - 10));
        StringFormat sfCenter;
        sfCenter.SetAlignment(StringAlignmentCenter);
        sfCenter.SetLineAlignment(StringAlignmentCenter);
        g.DrawString(icon.emoji.c_str(), -1, g_fontEmojiLarge, emojiRect, &sfCenter, &emojiBr);

        // Название
        SolidBrush textBr(Colors::TextWhite);
        RectF textRect((REAL)(ix - 10), (REAL)(iy + DESKTOP_ICON_SIZE - 10),
            (REAL)(DESKTOP_ICON_SIZE + 20), 30);
        g.DrawString(icon.name.c_str(), -1, g_fontDesktopIcon, textRect, &sf, &textBr);
    }
}

