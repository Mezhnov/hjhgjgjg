int main() {
    SetConsoleOutputCP(CP_UTF8);
    SetConsoleCP(CP_UTF8);
    srand(GetTickCount());

    cout << "========================================\n";
    cout << "  AUTO TYPER: Vizualnaya pechat v PyCharm\n";
    cout << "========================================\n\n";

    // === СБОР ДАННЫХ ===
    string projectName, basePath, filename, codeSourcePath;

    cout << "Nazvanie proekta: ";
    getline(cin, projectName);

    cout << "Papka dlya proektov (naprimer C:\\Projects): ";
    getline(cin, basePath);
    string projectPath = basePath + "\\" + projectName;

    cout << "Imya faila (naprimer main.py): ";
    getline(cin, filename);

    cout << "\nIstochnik koda:\n   1 - Vvesti vruchnuyu\n   2 - Iz faila\n   Vybor: ";
    int mode;
    cin >> mode;
    cin.ignore();

    string code;
    if (mode == 1) {
        cout << "\nVvodi kod. Chtoby zakonchit' - napishi END na otdelnoi stroke:\n";
        cout << "----------------------------------------\n";
        string line;
        while (getline(cin, line) && line != "END") {
            code += line + "\n";
        }
    }
    else {
        cout << "Put' k failu s kodom: ";
        getline(cin, codeSourcePath);
        ifstream f(codeSourcePath);
        if (!f) {
            cout << "NE udalos otkryt' fail!\n";
            return 1;
        }
        code = string((istreambuf_iterator<char>(f)), {});
        f.close();
    }

    cout << "\nZaderzhka mezhdu simvolami (30-80 ms): ";
    int delay;
    cin >> delay;
    if (delay < 10) delay = 30;

    cout << "\nPut' k pycharm64.exe (ostav' pustym, esli v PATH): ";
    cin.ignore();
    string pycharmPath;
    getline(cin, pycharmPath);

    // === ПОДГОТОВКА ===
    cout << "\n----------------------------------------\n";
    cout << "PODGOTOVKA...\n";

    cout << "[1/5] Sozdayu papku proekta... ";
    if (!createFolder(projectPath)) {
        cout << "OSHBKA!\n";
        return 1;
    }
    cout << "OK\n";

    string fullFilepath = projectPath + "\\" + filename;
    cout << "[2/5] Sozdayu pustoy fail " << filename << "... ";
    if (!saveEmptyFile(fullFilepath)) {
        cout << "OSHBKA!\n";
        return 1;
    }
    cout << "OK\n";

    cout << "[3/5] Zapuskayu PyCharm... ";
    if (!launchPyCharm(projectPath, pycharmPath)) {
        cout << "Ne udalos zapustit'!\n";
        return 1;
    }
    cout << "OK\n";

    cout << "[4/5] Ozhidanie zagruzki PyCharm (" << PYCHARM_WAIT_SEC << " sek)...\n";
    cout << "     SОВЕТ: Ne svorachivai PyCharm!\n\n";

    for (int i = PYCHARM_WAIT_SEC; i > 0; i--) {
        cout << "\r     " << i << " sek...";
        cout.flush();
        Sleep(1000);
    }
    cout << "\n     PyCharm dolzhen byt' gotov!\n\n";

    if (!activatePyCharm()) {
        cout << "\nPyCharm ne naiden! Zapusti ego vruchnuyu i nazhmi Enter...";
        cin.get();
        activatePyCharm();
    }

    Sleep(500);

    openFileInPyCharm(filename);
    Sleep(500);

    if (CLEAR_FILE_FIRST) {
        cout << "[5/5] Ochishchayu fail... ";
        clearFileContent();
        cout << "OK\n\n";
    }

    // === ПЕЧАТЬ ===
    int wsize = MultiByteToWideChar(CP_UTF8, 0, code.c_str(), -1, NULL, 0);
    wchar_t* wbuf = new wchar_t[wsize];
    MultiByteToWideChar(CP_UTF8, 0, code.c_str(), -1, wbuf, wsize);
    wstring wcode = wbuf;
    delete[] wbuf;

    cout << "========================================\n";
    cout << "  VNIMANIE NA OKNO PYCHARM!\n";
    cout << "  Pechat' nachnyotsya cherez 3 sek...\n";
    cout << "  Nazhmi ESC dlya ostanovki\n";
    cout << "========================================\n";

    for (int i = 3; i > 0; i--) {
        cout << "\r>>> " << i << "...";
        cout.flush();
        Sleep(1000);
    }
    cout << "\n\n";

    typeWithAnimation(wcode, delay);

    cout << "\nGOTOVO! Kod napechatan v PyCharm.\n";
    cout << "Ne zabud' sokhranit' fail (Ctrl+S)!\n\n";

    return 0;
}
