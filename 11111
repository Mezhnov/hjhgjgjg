        {L"Браузер", L"🌐"},
        {L"Терминал", L"⬛"},
        {L"Магазин", L"🛒"},
        {L"Настройки", L"⚙"},
        {L"Фотографии", L"🖼"},
        {L"Музыка", L"🎵"},
