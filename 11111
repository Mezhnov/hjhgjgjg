lor ColorFromRGB(COLORREF clr, BYTE alpha = 255) {     return Color(alpha, GetRValue(clr), GetGValue(clr), GetBValue(clr)); }  int GetScreenWidth() { return GetSystemMetrics(SM_CXSCREEN); } int GetScreenHeight() { return GetSystemMetrics(SM_CYSCREEN); }  // Глобальное время для анимаций DWORD g_animationTime = 0;  void AddRoundedRect(GraphicsPath& path, int x, int y, int w, int h, int radius) {     int r2 = radius * 2;     path.AddArc(x, y, r2, r2, 180, 90);     path.AddArc(x + w - r2, y, r2, r2, 270, 90);     path.AddArc(x + w - r2, y + h - r2, r2, r2, 0, 90);     path.AddArc(x, y + h - r2, r2, r2, 90, 90);     path.CloseFigure(); }  void FillRoundRect(Graphics& g, int x, int y, int w, int h, int radius, Color color) {     SolidBrush brush(color);     GraphicsPath path;     AddRoundedRect(path, x, y, w, h, radius);     g.FillPath(&brush, &path); }  void DrawRoundRect(Graphics& g, int x, int y, int w, int h, int radius, Color color, float width = 1.0f) {     Pen pen(color, width);     GraphicsPath path;     AddRoundedRect(path, x, y, w, h, radius);     g.DrawPath(&pen, &path); }  // ========== УНИКАЛЬНЫЙ ЛОГОТИП VORTEX (ВИХРЬ) ========== void DrawVortexLogo(Graphics& g, int x, int y, int size, Color color, bool animated = true) {     float rotation = 0.0f;     if (animated) {         rotation = (g_animationTime % 4000) / 4000.0f * 360.0f;     }      int cx = x + size / 2;     int cy = y + size / 2;      // Внешнее свечение     for (int i = 3; i >= 1; i--) {         SolidBrush glowBrush(Color(30, color.GetRed(), color.GetGreen(), color.GetBlue()));         GraphicsPath glowPath;         AddRoundedRect(glowPath, x - i, y - i, size + i * 2, size + i * 2, size / 2);         g.FillPath(&glowBrush, &glowPath);     }      // Основной круг с градиентом     LinearGradientBrush circleBrush(         Rect(x, y, size, size),         VortexColors::AccentLight,         VortexColors::AccentDark,         LinearGradientModeVertical     );     g.FillEllipse(&circleBrush, x, y, size, size);      // Вращающийся вихрь     GraphicsState state = g.Save();     g.TranslateTransform((REAL)cx, (REAL)cy);     g.RotateTransform(rotation);     g.TranslateTransform(-(REAL)cx, -(REAL)cy);      Pen spiralPen(color, 2.5f);      // Рисуем спираль вихря     for (int arm = 0; arm < 3; arm++) {         GraphicsPath spiralPath;         float armOffset = arm * 120.0f;          for (float angle = 0; angle < 720; angle += 5) {             float rad = (angle + armOffset) * 3.14159f / 180.0f;             float r = size * 0.1f + (angle / 720.0f) * size * 0.35f;             float px = cx + cos(rad) * r;             float py = cy + sin(rad) * r;              if (angle == 0) {                 spiralPath.AddLine(px, py, px, py);             }             else {             }         }         g.DrawPath(&spiralPen, &spiralPath);     }      g.Restore(state);      // Центральная точка     SolidBrush centerBrush(Color(255, 255, 255, 255));     g.FillEllipse(&centerBrush, cx - 3, cy - 3, 6, 6); }  // ========== ИНДИКАТОР СИСТЕМЫ (CPU/RAM) ========== void DrawSystemIndicator(Graphics& g, int x, int y, int w, int h, int cpuPercent, int ramPercent) {     // Фон     GraphicsPath bgPath;     AddRoundedRect(bgPath, x, y, w, h, 6);     SolidBrush bgBrush(VortexColors::WidgetBg);     g.FillPath(&bgBrush, &bgPath);      // CPU бар     int barH = (h - 12) / 2 - 2;     int barY = y + 6;      SolidBrush cpuBg(Color(40, 255, 255, 255));     g.FillRectangle(&cpuBg, x + 28, barY, w - 34, barH);      Color cpuColor = cpuPercent > 80 ? VortexColors::Danger :         cpuPercent > 50 ? VortexColors::Warning : VortexColors::Success;     SolidBrush cpuFill(cpuColor);     g.FillRectangle(&cpuFill, x + 28, barY, (int)((w - 34) * cpuPercent / 100.0f), barH);      // RAM бар     barY += barH + 4;     g.FillRectangle(&cpuBg, x + 28, barY, w - 34, barH);      Color ramColor = ramPercent > 80 ? VortexColors::Danger :         ramPercent > 50 ? VortexColors::Warning : VortexColors::Success;     SolidBrush ramFill(ramColor);     g.FillRectangle(&ramFill, x + 28, barY, (int)((w - 34) * ramPercent / 100.0f), barH);      // Лейблы     FontFamily fontFamily(L"Segoe UI");     Font labelFont(&fontFamily, 9.0f, FontStyleBold, UnitPixel);     SolidBrush labelBrush(VortexColors::TextPrimary);      StringFormat format;     format.SetAlignment(StringAlignmentCenter);     format.SetLineAlignment(StringAlignmentCenter);      RectF cpuLabelRect((REAL)(x + 2), (REAL)(y + 4), 24.0f, (REAL)barH);     g.DrawString(L"CPU", -1, &labelFont, cpuLabelRect, &format, &labelBrush);      RectF ramLabelRect((REAL)(x + 2), (REAL)(barY), 24.0f, (REAL)barH);     g.DrawString(L"RAM", -1, &labelFont, ramLabelRect, &format, &labelBrush); }  // ========== ПОГОДА С АНИМАЦИЕЙ ========== void DrawWeatherWidget(Graphics& g, int x, int y, bool animated = true) {     // Анимация солнца     float pulseScale = 1.0f;     if (animated) {         pulseScale = 1.0f + sin(g_animationTime / 500.0f) * 0.1f;     }      int sunSize = (int)(24 * pulseScale);     int sunX = x + 12 - (sunSize - 24) / 2;     int sunY = y + 1 - (sunSize - 24) / 2;      // Солнце с лучами     int sunCx = sunX + sunSize / 2;     int sunCy = sunY + sunSize / 2;      // Лучи     Pen rayPen(Color(255, 251, 191, 36), 2.0f);     for (int i = 0; i < 8; i++) {         float angle = i * 45.0f * 3.14159f / 180.0f;         float innerR = sunSize * 0.6f;         float outerR = sunSize * 0.9f;         g.DrawLine(&rayPen,             sunCx + cos(angle) * innerR, sunCy + sin(angle) * innerR,             sunCx + cos(angle) * outerR, sunCy + sin(angle) * outerR);     }      // Солнце     LinearGradientBrush sunBrush(         Rect(sunX, sunY, sunSize, sunSize),         Color(255, 253, 224, 71),         Color(255, 251, 146, 60),         LinearGradientModeVertical     );     g.FillEllipse(&sunBrush, sunX, sunY, sunSize, sunSize); }  // ========== МУЗЫКАЛЬНЫЙ ПЛЕЕР ========== void DrawMusicPlayer(Graphics& g, int x, int y, int w, int h, bool isPlaying) {     // Фон     GraphicsPath bgPath;     AddRoundedRect(bgPath, x, y, w, h, 8);      LinearGradientBrush bgBrush(         Rect(x, y, w, h),         Color(80, 139, 92, 246),         Color(60, 109, 40, 217),         LinearGradientModeVertical     );     g.FillPath(&bgBrush, &bgPath);      // Свечение при воспроизведении     if (isPlaying) {         Pen glowPen(VortexColors::Glow, 2.0f);         g.DrawPath(&glowPen, &bgPath);     }      // Иконка воспроизведения     int iconSize = 20;     int iconX = x + 8;     int iconY = y + (h - iconSize) / 2;      if (isPlaying) {         // Pause icon         SolidBrush iconBrush(VortexColors::TextPrimary);         g.FillRectangle(&iconBrush, iconX, iconY + 2, 4, iconSize - 4);         g.FillRectangle(&iconBrush, iconX + 8, iconY + 2, 4, iconSize - 4);     }     else {         // Play icon         Point playPts[3] = {             Point(iconX, iconY),             Point(iconX, iconY + iconSize),             Point(iconX + iconSize, iconY + iconSize / 2)         };         SolidBrush iconBrush(VortexColors::TextPrimary);         g.FillPolygon(&iconBrush, playPts, 3);     }      // Название трека     FontFamily fontFamily(L"Segoe UI");     Font titleFont(&fontFamily, 10.0f, FontStyleBold, UnitPixel);     Font artistFont(&fontFamily, 8.0f, FontStyleRegular, UnitPixel);      SolidBrush titleBrush(VortexColors::TextPrimary);     SolidBrush artistBrush(VortexColors::TextSecondary);      StringFormat format;     format.SetAlignment(StringAlignmentNear);     format.SetLineAlignment(StringAlignmentNear);      RectF titleRect((REAL)(x + 34), (REAL)(y + 4), (REAL)(w - 42), 12.0f);     g.DrawString(L"Blinding Lights", -1, &titleFont, titleRect, &format, &titleBrush);      RectF artistRect((REAL)(x + 34), (REAL)(y + 16), (REAL)(w - 42), 12.0f);     g.DrawString(L"The Weeknd", -1, &artistFont, artistRect, &format, &artistBrush);      // Прогресс бар     int progressY = y + h - 6;     SolidBrush progressBg(Color(60, 255, 255, 255));     g.FillRectangle(&progressBg, x + 4, progressY, w - 8, 3);      SolidBrush progressFill(VortexColors::AccentLight);     g.FillRectangle(&progressFill, x + 4, progressY, (int)((w - 8) * 0.65f), 3); }  // ========== УВЕДОМЛЕНИЯ ========== struct Notification {     std::wstring title;     std::wstring message;     std::wstring icon;     DWORD showTime;     float alpha;     float yOffset;     bool visible; };  std::vector<Notification> g_notifications;  void DrawNotification(Graphics& g, int screenW, int y) {     if (g_notifications.empty() || !g_notifications[0].visible) return;      Notification& notif = g_notifications[0];      int notifW = 320;     int notifH = 70;     int notifX = screenW - notifW - 20;     int notifY = (int)(40 + notif.yOffset);      // Фон с прозрачностью     GraphicsPath notifPath;     AddRoundedRect(notifPath, notifX, notifY, notifW, notifH, 12);      SolidBrush bgBrush(Color((BYTE)(220 * notif.alpha), 30, 30, 40));     g.FillPath(&bgBrush, &notifPath);      Pen borderPen(Color((BYTE)(60 * notif.alpha), 139, 92, 246), 1.5f);     g.DrawPath(&borderPen, &notifPath);      // Иконка     int iconX = notifX + 12;     int iconY = notifY + 15;     DrawVortexLogo(g, iconX, iconY, 40, VortexColors::AccentLight, false);      // Текст     FontFamily fontFamily(L"Segoe UI");     Font titleFont(&fontFamily, 12.0f, FontStyleBold, UnitPixel);     Font msgFont(&fontFamily, 10.0f, FontStyleRegular, UnitPixel);      SolidBrush titleBrush(Color((BYTE)(255 * notif.alpha), 255, 255, 255));     SolidBrush msgBrush(Color((BYTE)(200 * notif.alpha), 200, 200, 200));      StringFormat format;     format.SetAlignment(StringAlignmentNear);     format.SetLineAlignment(StringAlignmentNear);      RectF titleRect((REAL)(notifX + 62), (REAL)(notifY + 14), (REAL)(notifW - 80), 16.0f);     g.DrawString(notif.title.c_str(), -1, &titleFont, titleRect, &format, &titleBrush);      RectF msgRect((REAL)(notifX + 62), (REAL)(notifY + 32), (REAL)(notifW - 80), 30.0f);     g.DrawString(notif.message.c_str(), -1, &msgFont, msgRect, &format, &msgBrush); }  // ========== БЫСТРЫЕ ДЕЙСТВИЯ (QUICK ACTIONS) ========== void DrawQuickActions(Graphics& g, int x, int y, bool expanded) {     int actionSize = 32;     int spacing = 8;     int visibleCount = expanded ? 4 : 2;      struct Action {         const wchar_t* name;         Color color;         bool active;     };      Action actions[] = {         { L"WiFi", VortexColors::Success, true },         { L"BT", VortexColors::Accent, true },         { L"DND", VortexColors::Danger, false },         { L"Night", VortexColors::Warning, false }     };      for (int i = 0; i < visibleCount; i++) {         int ax = x + i * (actionSize + spacing);          // Фон         GraphicsPath actionPath;         AddRoundedRect(actionPath, ax, y, actionSize, actionSize, 8);          Color bgColor = actions[i].active ?             Color(180, actions[i].color.GetRed(), actions[i].color.GetGreen(), actions[i].color.GetBlue()) :             Color(80, 60, 60, 70);          SolidBrush actionBrush(bgColor);         g.FillPath(&actionBrush, &actionPath);          if (actions[i].active) {             Pen glowPen(Color(100, actions[i].color.GetRed(), actions[i].color.GetGreen(), actions[i].color.GetBlue()), 2.0f);             g.DrawPath(&glowPen, &actionPath);         }          // Иконка/текст         FontFamily fontFamily(L"Segoe UI");         Font iconFont(&fontFamily, 10.0f, FontStyleBold, UnitPixel);         SolidBrush iconBrush(actions[i].active ? Color(255, 255, 255, 255) : Color(150, 200, 200, 200));          StringFormat format;         format.SetAlignment(StringAlignmentCenter);         format.SetLineAlignment(StringAlignmentCenter);          RectF iconRect((REAL)ax, (REAL)y, (REAL)actionSize, (REAL)actionSize);         g.DrawString(actions[i].name, -1, &iconFont, iconRect, &format, &iconBrush);     } }  // ========== ГЛАВНОЕ МЕНЮ VORTEX ========== void DrawVortexMenu(Graphics& g, int x, int y, int w, int h, bool hovered) {     // Фон меню     GraphicsPath menuPath;     AddRoundedRect(menuPath, x, y, w, h, 10);      Color bgColor = hovered ?         Color(180, 139, 92, 246) :         Color(120, 30, 30, 45);      SolidBrush menuBrush(bgColor);     g.FillPath(&menuBrush, &menuPath);      if (hovered) {         Pen glowPen(VortexColors::Glow, 2.0f);         g.DrawPath(&glowPen, &menuPath);     }      FontFamily fontFamily(L"Segoe UI");     Font menuFont(&fontFamily, 11.0f, FontStyleBold, UnitPixel);     SolidBrush textBrush(VortexColors::TextPrimary);      StringFormat format;     format.SetAlignment(StringAlignmentCenter);     format.SetLineAlignment(StringAlignmentCenter);      RectF textRect((REAL)x, (REAL)y, (REAL)w, (REAL)h);     g.DrawString(L"VORTEX", -1, &menuFont, textRect, &format, &textBrush); }  // Draw macOS style icon void DrawMacOSIcon(Graphics& g, int x, int y, int size, Color baseColor, const wchar_t* letter, float scale = 1.0f) {     int scaledSize = (int)(size * scale);     int offsetX = (scaledSize - size) / 2;     int offsetY = (scaledSize - size) / 2;     int px = x - offsetX;     int py = y - offsetY;     int radius = (int)(scaledSize * 0.2f);      // Shadow     for (int i = 2; i >= 1; i--) {         SolidBrush shadowBrush(Color(40 + i * 15, 0, 0, 0));         GraphicsPath shadowPath;         AddRoundedRect(shadowPath, px + i, py + i + 2, scaledSize, scaledSize, radius);         g.FillPath(&shadowBrush, &shadowPath);     }      // Gradient background     REAL r = (REAL)baseColor.GetRed();     REAL gVal = (REAL)baseColor.GetGreen();     REAL b = (REAL)baseColor.GetBlue();      BYTE topR = (BYTE)((r * 1.25f > 255.0f) ? 255 : (int)(r * 1.25f));     BYTE topG = (BYTE)((gVal * 1.25f > 255.0f) ? 255 : (int)(gVal * 1.25f));     BYTE topB = (BYTE)((b * 1.25f > 255.0f) ? 255 : (int)(b * 1.25f));     BYTE botR = (BYTE)(r * 0.75f);     BYTE botG = (BYTE)(gVal * 0.75f);     BYTE botB = (BYTE)(b * 0.75f);      LinearGradientBrush gradientBrush(         Rect(px, py, scaledSize, scaledSize),         Color(255, topR, topG, topB),         Color(255, botR, botG, botB),         LinearGradientModeVertical     );      GraphicsPath iconPath;     AddRoundedRect(iconPath, px, py, scaledSize, scaledSize, radius);     g.FillPath(&gradientBrush, &iconPath);      // Glossy highlight     GraphicsPath clipPath;     AddRoundedRect(clipPath, px, py, scaledSize, scaledSize, radius);     GraphicsState state = g.Save();     g.SetClip(&clipPath);      LinearGradientBrush glossBrush(         Rect(px, py, scaledSize, scaledSize / 2),         Color(70, 255, 255, 255),         Color(0, 255, 255, 255),         LinearGradientModeVertical     );     g.FillRectangle(&glossBrush, px, py, scaledSize, scaledSize / 2);     g.Restore(state);      // Border     Pen borderPen(Color(60, 255, 255, 255), 1.0f);     g.DrawPath(&borderPen, &iconPath);      // Letter     FontFamily fontFamily(L"Segoe UI");     Font iconFont(&fontFamily, scaledSize * 0.42f, FontStyleBold, UnitPixel);     SolidBrush textBrush(Color(255, 255, 255, 255));      StringFormat format;     format.SetAlignment(StringAlignmentCenter);     format.SetLineAlignment(StringAlignmentCenter);      RectF textRect;     textRect.X = (REAL)px;     textRect.Y = (REAL)py - 1;     textRect.Width = (REAL)scaledSize;     textRect.Height = (REAL)scaledSize;     g.DrawString(letter, -1, &iconFont, textRect, &format, &textBrush); }  // Draw Wi-Fi icon void DrawWifiIcon(Graphics& g, int x, int y, int size, Color color) {     Pen pen(color, 2.0f);     SolidBrush dotBrush(color);      int cx = x + size / 2;     int cy = y + size - 2;      for (int i = 0; i < 3; i++) {         int arcR = size / 2 - i * (size / 5);         int arcY = cy - arcR - i * (size / 6);         if (arcR > 2) {             g.DrawArc(&pen, cx - arcR, arcY, arcR * 2, arcR * 2, 220, 100);         }     }      g.FillEllipse(&dotBrush, cx - 2, cy - 2, 4, 4); }  // Draw Battery icon void DrawBatteryIcon(Graphics& g, int x, int y, int w, int h, int percent, Color color) {     Pen pen(color, 1.5