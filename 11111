// ===== НАСТРОЙКИ =====
const int DEFAULT_DELAY = 50;
const int PYCHARM_WAIT_SEC = 12;
const bool CLEAR_FILE_FIRST = true;

// ===== ОТПРАВКА КЛАВИШ =====
void sendUnicodeChar(wchar_t wc) {
    INPUT input[2] = {};
    input[0].type = INPUT_KEYBOARD;
    input[0].ki.wScan = wc;
    input[0].ki.dwFlags = KEYEVENTF_UNICODE;
    input[1].type = INPUT_KEYBOARD;
    input[1].ki.wScan = wc;
    input[1].ki.dwFlags = KEYEVENTF_UNICODE | KEYEVENTF_KEYUP;
    SendInput(2, input, sizeof(INPUT));
}

void sendKey(WORD vk, bool extended = false) {
    INPUT input[2] = {};
    input[0].type = INPUT_KEYBOARD;
    input[0].ki.wVk = vk;
    if (extended) input[0].ki.dwFlags = KEYEVENTF_EXTENDEDKEY;
    input[1].type = INPUT_KEYBOARD;
    input[1].ki.wVk = vk;
    input[1].ki.dwFlags = KEYEVENTF_KEYUP | (extended ? KEYEVENTF_EXTENDEDKEY : 0);
    SendInput(2, input, sizeof(INPUT));
}

void sendCtrl(char key) {
    keybd_event(VK_CONTROL, 0, 0, 0);
    keybd_event(toupper(key), 0, 0, 0);
    keybd_event(toupper(key), 0, KEYEVENTF_KEYUP, 0);
    keybd_event(VK_CONTROL, 0, KEYEVENTF_KEYUP, 0);
}

void sendEnter() { sendKey(VK_RETURN); }
void sendTab() { sendKey(VK_TAB); }
void sendEscape() { sendKey(VK_ESCAPE); }

// ===== УПРАВЛЕНИЕ ОКНАМИ =====
bool waitForWindow(const wchar_t* titlePart, int timeoutSec = 30) {
    HWND hwnd = NULL;
    for (int i = 0; i < timeoutSec * 2; i++) {
        hwnd = FindWindowW(NULL, titlePart);
        if (hwnd) {
            SetForegroundWindow(hwnd);
            return true;
        }
        // Поиск по частичному совпадению
        EnumWindows([](HWND h, LPARAM lp) -> BOOL {
            wchar_t title[512];
            GetWindowTextW(h, title, 512);
            if (wcsstr(title, (const wchar_t*)lp)) {
                SetForegroundWindow(h);
                return FALSE;
            }
            return TRUE;
            }, (LPARAM)titlePart);

        Sleep(500);
    }
    return false;
}

bool activatePyCharm() {
    cout << "[*] Поиск окна PyCharm... ";
    if (waitForWindow(L"PyCharm", 20)) {
        cout << "NAIDENO\n";
        Sleep(500);
        HWND hwnd = FindWindowW(NULL, L"PyCharm");
        if (!hwnd) {
            EnumWindows([](HWND h, LPARAM) -> BOOL {
                wchar_t title[512];
                GetWindowTextW(h, title, 512);
                if (wcsstr(title, L"PyCharm")) {
                    SetForegroundWindow(h);
                    return FALSE;
                }
                return TRUE;
                }, 0);
        }
        return true;
    }
    cout << "NE NAIDENO\n";
    return false;
}

// ===== НАВИГАЦИЯ В PYCHARM =====
void openFileInPyCharm(const string& filename) {
    cout << "[*] Otkrivayu fail " << filename << " v redaktore...\n";

    sendCtrl('O');
    Sleep(800);

    // Печатаем имя файла посимвольно
    for (char c : filename) {
        sendUnicodeChar(static_cast<wchar_t>(c));
        Sleep(30);
    }
    Sleep(300);

    sendEnter(); // Открыть файл
    Sleep(1000);

    sendEnter(); // Подтвердить создание если нужно
    Sleep(500);

    sendEscape(); // Закрыть панели
    Sleep(300);

    activatePyCharm();
    Sleep(200);
}

void clearFileContent() {
    sendCtrl('A');
    Sleep(200);
    sendKey(VK_DELETE);
    Sleep(300);
}

// ===== ПЕЧАТЬ С АНИМАЦИЕЙ =====
void typeWithAnimation(const wstring& text, int delayMs) {
    cout << "\n[>] NACHINAYU PECHAT'! Smotri na PyCharm\n\n";

    for (size_t i = 0; i < text.size(); i++) {
        if (GetAsyncKeyState(VK_ESCAPE) & 0x8000) {
            cout << "\n[!] Ostanovleno polzovatelem\n";
            break;
        }

        wchar_t wc = text[i];

        if (wc == L'\n') {
            sendEnter();
        }
        else if (wc == L'\t') {
            sendTab();
        }
        else if (wc == L'\r') {
            continue;
        }
        else {
            sendUnicodeChar(wc);
        }

        if (i % 10 == 0) {
            cout << "\r[>] Napechatano: " << i << "/" << text.size();
            cout.flush();
        }

        int randDelay = delayMs + (rand() % (delayMs / 3 + 1));
        Sleep(randDelay);
    }
    cout << "\n\r[OK] Pechat' zavershena! (" << text.size() << " simvolov)\n";
}

// ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
bool createFolder(const string& path) {
    return _mkdir(path.c_str()) == 0 || GetLastError() == ERROR_ALREADY_EXISTS;
}

bool saveEmptyFile(const string& filepath) {
    ofstream f(filepath, ios::out | ios::trunc);
    return f.is_open();
}

bool launchPyCharm(const string& projectPath, const string& pycharmExe = "") {
    string cmd = pycharmExe.empty() ?
        "pycharm64.exe \"" + projectPath + "\"" :
        "\"" + pycharmExe + "\" \"" + projectPath + "\"";

    // Конвертируем в wide string для Windows API
    wstring wcmd(cmd.begin(), cmd.end());
    wstring wparams = L"/c start \"PyCharm\" \"" + wcmd + L"\"";

    SHELLEXECUTEINFOW sei = { sizeof(sei) };
    sei.lpFile = L"cmd.exe";  // <-- L"..." для Unicode!
    sei.lpParameters = wparams.c_str();
    sei.nShow = SW_SHOWNORMAL;

    return ShellExecuteExW(&sei) && sei.hProcess != NULL;
}

