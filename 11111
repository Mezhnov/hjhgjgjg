// ==================== ОСНОВНОЙ WNDPROC ====================
LRESULT CALLBACK WndProc(HWND hWnd, UINT message, WPARAM wParam, LPARAM lParam)
{
    switch (message)
    {
    case WM_CREATE:
    {
        SetTimer(hWnd, ID_TIMER_CLOCK, 1000, NULL);
        g_hDownloadThread = CreateThread(NULL, 0, ImageDownloader::DownloadThreadProc, NULL, 0, NULL);

        UpdateDateTime();

        g_hFontTime = CreateFontW(15, 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE,
            DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
            DEFAULT_QUALITY, DEFAULT_PITCH | FF_DONTCARE, L"Segoe UI");
        g_hFontDate = CreateFontW(12, 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE,
            DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
            DEFAULT_QUALITY, DEFAULT_PITCH | FF_DONTCARE, L"Segoe UI");
        g_hFontMenu = CreateFontW(14, 0, 0, 0, FW_NORMAL, FALSE, FALSE, FALSE,
            DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
            DEFAULT_QUALITY, DEFAULT_PITCH | FF_DONTCARE, L"Segoe UI");
        g_hFontMenuBold = CreateFontW(14, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE,
            DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS,
            DEFAULT_QUALITY, DEFAULT_PITCH | FF_DONTCARE, L"Segoe UI");

        SendMessage(g_hWndStart, WM_SETFONT, (WPARAM)g_hFontMenuBold, TRUE);
        SendMessage(g_hWndLang, WM_SETFONT, (WPARAM)g_hFontMenu, TRUE);
        SendMessage(g_hWndClock, WM_SETFONT, (WPARAM)g_hFontTime, TRUE);
        SendMessage(g_hWndDate, WM_SETFONT, (WPARAM)g_hFontDate, TRUE);
    }
    break;

    case WM_SIZE:
    {
        RECT rcParent;
        GetClientRect(hWnd, &rcParent);
        int width = rcParent.right - rcParent.left;
        int height = rcParent.bottom - rcParent.top;

        if (g_hWndTaskbar)
            MoveWindow(g_hWndTaskbar, 0, height - TASKBAR_HEIGHT, width, TASKBAR_HEIGHT, TRUE);

        if (g_hWndStart)
            MoveWindow(g_hWndStart, 0, 4, START_BTN_WIDTH, TASKBAR_HEIGHT - 8, TRUE);

        if (g_hWndLang)
            MoveWindow(g_hWndLang, width - LANG_WIDTH - CLOCK_WIDTH - 220, 6, LANG_WIDTH, TASKBAR_HEIGHT - 12, TRUE);

        if (g_hWndClock)
            MoveWindow(g_hWndClock, width - CLOCK_WIDTH - LANG_WIDTH - 10, 4, CLOCK_WIDTH, 22, TRUE);

        if (g_hWndDate)
            MoveWindow(g_hWndDate, width - CLOCK_WIDTH - LANG_WIDTH - 10, 24, CLOCK_WIDTH, 20, TRUE);

        if (g_hWndStartMenu)
            MoveWindow(g_hWndStartMenu, 0, height - TASKBAR_HEIGHT - START_MENU_HEIGHT,
                START_MENU_WIDTH, START_MENU_HEIGHT, TRUE);

        if (g_hdcMemory) DeleteDC(g_hdcMemory);
        if (g_hbmMemory) DeleteObject(g_hbmMemory);

        int clientHeight = height - TASKBAR_HEIGHT;
        g_hdcMemory = CreateCompatibleDC(NULL);
        g_hbmMemory = CreateCompatibleBitmap(NULL, width, clientHeight);
        SelectObject(g_hdcMemory, g_hbmMemory);
    }
    break;

    case WM_TIMER:
    {
        if (wParam == ID_TIMER_CLOCK)
        {
            UpdateDateTime();
        }
    }
    break;

    case WM_COMMAND:
    {
        int wmId = LOWORD(wParam);
        switch (wmId)
        {
        case 101:
            ToggleStartMenu();
            break;
        case 102:
            if (g_sCurrentLang == L"RU")
            {
                g_sCurrentLang = L"EN";
                SetWindowTextW(g_hWndLang, L"ENG");
                SetWindowTextW(g_hWndStart, L"▶ START");
            }
            else
            {
                g_sCurrentLang = L"RU";
                SetWindowTextW(g_hWndLang, L"RU");
                SetWindowTextW(g_hWndStart, L"▶ ПУСК");
            }
            break;
        }
    }
    break;

    case WM_LBUTTONDOWN:
        CloseStartMenu();
        break;

    case WM_PAINT:
    {
        PAINTSTRUCT ps;
        HDC hdc = BeginPaint(hWnd, &ps);

        RECT rcClient;
        GetClientRect(hWnd, &rcClient);
        int width = rcClient.right - rcClient.left;
        int height = rcClient.bottom - rcClient.top - TASKBAR_HEIGHT;

        if (g_bWallpaperLoaded && g_hbmWallpaper)
        {
            HDC hdcImage = CreateCompatibleDC(hdc);
            SelectObject(hdcImage, g_hbmWallpaper);
            StretchBlt(hdc, 0, 0, width, height, hdcImage, 0, 0, width, height, SRCCOPY);
            DeleteDC(hdcImage);
        }
        else
        {
            // Градиентный фон (если обои не загрузились)
            TRIVERTEX vertex[2];
            GRADIENT_RECT gRect;
            vertex[0].x = 0; vertex[0].y = 0;
            vertex[0].Red = 0x0000; vertex[0].Green = 0x3000; vertex[0].Blue = 0x5000;
            vertex[1].x = width; vertex[1].y = height;
            vertex[1].Red = 0x0000; vertex[1].Green = 0x1000; vertex[1].Blue = 0x2000;
            gRect.UpperLeft = 0; gRect.LowerRight = 1;
            GradientFill(hdc, vertex, 2, &gRect, 1, GRADIENT_FILL_RECT_V);
        }

        // Панель задач
        HDC hdcTaskbar = CreateCompatibleDC(hdc);
        HBITMAP hbmTaskbar = CreateCompatibleBitmap(hdc, width, TASKBAR_HEIGHT);
        SelectObject(hdcTaskbar, hbmTaskbar);

        HBRUSH hbrTaskbar = CreateSolidBrush(COLOR_TASKBAR);
        RECT rcTaskbar = { 0, 0, width, TASKBAR_HEIGHT };
        FillRect(hdcTaskbar, &rcTaskbar, hbrTaskbar);
        DeleteObject(hbrTaskbar);

        // Линия сверху панели
        HPEN hPen = CreatePen(PS_SOLID, 1, RGB(60, 60, 60));
        SelectObject(hdcTaskbar, hPen);
        MoveToEx(hdcTaskbar, 0, 0, NULL);
        LineTo(hdcTaskbar, width, 0);
        DeleteObject(hPen);

        BitBlt(hdc, 0, height, width, TASKBAR_HEIGHT, hdcTaskbar, 0, 0, SRCCOPY);

        DeleteObject(hbmTaskbar);
        DeleteDC(hdcTaskbar);

        EndPaint(hWnd, &ps);
    }
    break;

    case WM_ERASEBKGND:
        return TRUE;

    case WM_DESTROY:
    {
        KillTimer(hWnd, ID_TIMER_CLOCK);
        if (g_hDownloadThread) CloseHandle(g_hDownloadThread);
        if (g_hbmWallpaper) DeleteObject(g_hbmWallpaper);
        if (g_hdcMemory) DeleteDC(g_hdcMemory);
        if (g_hbmMemory) DeleteObject(g_hbmMemory);
        if (g_hFontTime) DeleteObject(g_hFontTime);
        if (g_hFontDate) DeleteObject(g_hFontDate);
        if (g_hFontMenu) DeleteObject(g_hFontMenu);
        if (g_hFontMenuBold) DeleteObject(g_hFontMenuBold);

        // ✅ ИСПРАВЛЕНО: Удаляем временный файл обоев
        if (!g_sTempImagePath.empty())
            DeleteFileW(g_sTempImagePath.c_str());

        PostQuitMessage(0);
    }
    break;

    default:
        return DefWindowProc(hWnd, message, wParam, lParam);
    }
    return 0;
}

// ==================== ТОЧКА ВХОДА ====================
int WINAPI WinMain(HINSTANCE hInstance, HINSTANCE hPrevInstance, LPSTR lpCmdLine, int nCmdShow)
{
    Gdiplus::GdiplusStartupInput gdiplusStartupInput;
    ULONG_PTR gdiplusToken;
    Gdiplus::GdiplusStartup(&gdiplusToken, &gdiplusStartupInput, NULL);
    CoInitialize(NULL);

    WNDCLASSEXW wcex = {};
    wcex.cbSize = sizeof(WNDCLASSEX);
    wcex.style = CS_HREDRAW | CS_VREDRAW;
    wcex.lpfnWndProc = WndProc;
    wcex.hInstance = hInstance;
    wcex.hCursor = LoadCursor(NULL, IDC_ARROW);
    wcex.hbrBackground = (HBRUSH)(COLOR_WINDOW + 1);
    wcex.lpszClassName = L"MyWindowsClass";
    RegisterClassExW(&wcex);

    WNDCLASSEXW wcMenu = {};
    wcMenu.cbSize = sizeof(WNDCLASSEX);
    wcMenu.style = CS_HREDRAW | CS_VREDRAW;
    wcMenu.lpfnWndProc = StartMenuProc;
    wcMenu.hInstance = hInstance;
    wcMenu.hCursor = LoadCursor(NULL, IDC_ARROW);
    wcMenu.hbrBackground = (HBRUSH)CreateSolidBrush(COLOR_MENU_BG);
    wcMenu.lpszClassName = L"StartMenuClass";
    RegisterClassExW(&wcMenu);

    WNDCLASSEXW wcClock = {};
    wcClock.cbSize = sizeof(WNDCLASSEX);
    wcClock.style = CS_HREDRAW | CS_VREDRAW;
    wcClock.lpfnWndProc = ClockProc;
    wcClock.hInstance = hInstance;
    wcClock.hCursor = LoadCursor(NULL, IDC_ARROW);
    wcClock.hbrBackground = NULL;
    wcClock.lpszClassName = L"ClockClass";
    RegisterClassExW(&wcClock);

    WNDCLASSEXW wcDate = {};
    wcDate.cbSize = sizeof(WNDCLASSEX);
    wcDate.style = CS_HREDRAW | CS_VREDRAW;
    wcDate.lpfnWndProc = DateProc;
    wcDate.hInstance = hInstance;
    wcDate.hCursor = LoadCursor(NULL, IDC_ARROW);
    wcDate.hbrBackground = NULL;
    wcDate.lpszClassName = L"DateClass";
    RegisterClassExW(&wcDate);

    g_hWndMain = CreateWindowExW(
        WS_EX_TOPMOST,
        L"MyWindowsClass",
        L"MyWindows OS",
        WS_POPUP | WS_VISIBLE,
        0, 0,
        GetSystemMetrics(SM_CXSCREEN),
        GetSystemMetrics(SM_CYSCREEN),
        NULL, NULL, hInstance, NULL
    );

    g_hWndTaskbar = CreateWindowExW(0, L"STATIC", L"",
        WS_CHILD | WS_VISIBLE, 0, 0, 0, 0, g_hWndMain, NULL, hInstance, NULL);

    g_hWndStart = CreateWindowExW(0, L"BUTTON", L"▶ ПУСК",
        WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON,
        0, 0, START_BTN_WIDTH, TASKBAR_HEIGHT - 8,
        g_hWndTaskbar, (HMENU)101, hInstance, NULL);

    g_hWndLang = CreateWindowExW(0, L"BUTTON", L"RU",
        WS_CHILD | WS_VISIBLE | BS_PUSHBUTTON,
        0, 0, LANG_WIDTH, TASKBAR_HEIGHT - 12,
        g_hWndTaskbar, (HMENU)102, hInstance, NULL);

    g_hWndClock = CreateWindowExW(0, L"ClockClass", L"00:00",
        WS_CHILD | WS_VISIBLE,
        0, 0, CLOCK_WIDTH, 22,
        g_hWndTaskbar, (HMENU)103, hInstance, NULL);

    g_hWndDate = CreateWindowExW(0, L"DateClass", L"01.01.2023, Понедельник",
        WS_CHILD | WS_VISIBLE,
        0, 0, CLOCK_WIDTH, 20,
        g_hWndTaskbar, (HMENU)104, hInstance, NULL);

    CreateStartMenu(g_hWndMain, hInstance);

    // Устанавливаем прозрачность для меню
    SetWindowLongW(g_hWndStartMenu, GWL_EXSTYLE,
        GetWindowLongW(g_hWndStartMenu, GWL_EXSTYLE) | WS_EX_LAYERED);
    SetLayeredWindowAttributes(g_hWndStartMenu, 0, 255, LWA_ALPHA);

    ShowWindow(g_hWndMain, SW_SHOWMAXIMIZED);
    UpdateWindow(g_hWndMain);

    MSG msg;
    while (GetMessage(&msg, NULL, 0, 0))
    {
        TranslateMessage(&msg);
        DispatchMessage(&msg);
    }

    Gdiplus::GdiplusShutdown(gdiplusToken);
    CoUninitialize();

    return (int)msg.wParam;
}
