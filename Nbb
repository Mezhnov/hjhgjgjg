<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Researcher — Microsoft 365 Copilot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;500;600&amp;display=swap');
        
        :root {
            --win-accent: #0078d4;
        }
        
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }
        
        .window {
            box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4);
            border: 1px solid #e5e7eb;
        }
        
        .titlebar {
            background: linear-gradient(to right, #f8fafc, #f1f5f9);
        }
        
        .sidebar-item {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .sidebar-item:hover {
            background-color: #f8fafc;
        }
        
        .sidebar-item-active {
            background-color: #eff6ff;
            color: #1e40af;
            border-left: 3px solid #3b82f6;
        }
        
        .suggestion-card {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .suggestion-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }
        
        .input-focus {
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
        }
        
        .wave-bg {
            background: linear-gradient(135deg, #0ea5e9 0%, #3b82f6 100%);
        }
        
        .fake-chat {
            animation: fadeIn 0.3s ease forwards;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-zinc-900 flex items-center justify-center min-h-screen p-8">
    <!-- Окно Windows 11 -->
    <div id="window" class="window bg-white w-[1180px] h-[680px] rounded-3xl overflow-hidden flex flex-col">
        
        <!-- Title Bar (Windows 11 стиль) -->
        <div class="titlebar h-11 flex items-center px-3 border-b border-gray-200 select-none">
            <div class="flex items-center gap-2 flex-1">
                <!-- Copilot иконка -->
                <div class="w-6 h-6 bg-gradient-to-br from-violet-500 via-blue-500 to-cyan-500 rounded-lg flex items-center justify-center shadow-inner">
                    <span class="text-white text-[15px] leading-none font-bold">✦</span>
                </div>
                <div>
                    <span class="font-semibold text-sm text-gray-800">Microsoft 365 Copilot</span>
                    <span class="text-[10px] text-gray-500 ml-1">— Researcher</span>
                </div>
            </div>
            
            <!-- Окно заголовок по центру -->
            <div class="flex-1 text-center">
                <span class="text-xs font-medium text-gray-500 tracking-widest">RESEARCHER</span>
            </div>
            
            <!-- Кнопки управления окном -->
            <div class="flex items-center gap-1">
                <button onclick="minimize()" 
                        class="w-8 h-8 hover:bg-gray-200 rounded-md flex items-center justify-center text-gray-600 text-xl leading-none">
                    &#x2012;
                </button>
                <button onclick="maximize()" 
                        class="w-8 h-8 hover:bg-gray-200 rounded-md flex items-center justify-center text-gray-600 text-lg leading-none">
                    ☐
                </button>
                <button onclick="closeWindow()" 
                        class="w-8 h-8 hover:bg-red-500 hover:text-white rounded-md flex items-center justify-center text-gray-600 text-xl leading-none">
                    ✕
                </button>
            </div>
        </div>
        
        <div class="flex flex-1 overflow-hidden">
            
            <!-- Боковая панель -->
            <div class="w-72 bg-white border-r border-gray-200 flex flex-col">
                
                <!-- Поиск -->
                <div class="p-4">
                    <div class="relative">
                        <input type="text" id="search" 
                               class="w-full bg-gray-100 border border-transparent focus:border-gray-300 focus:bg-white rounded-2xl py-2.5 pl-10 text-sm placeholder-gray-400 focus:outline-none"
                               placeholder="Поиск">
                        <i class="fa-solid fa-magnifying-glass absolute left-4 top-3 text-gray-400"></i>
                    </div>
                </div>
                
                <!-- Навигация -->
                <div class="px-2">
                    <div onclick="switchTab(0)" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-comments w-5 text-gray-500"></i>
                        <span class="font-medium">Chat</span>
                    </div>
                    <div onclick="switchTab(1)" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer bg-blue-50 text-blue-700 border-l-4 border-blue-600">
                        <i class="fa-solid fa-magnifying-glass w-5"></i>
                        <span class="font-medium">Researcher</span>
                    </div>
                </div>
                
                <!-- Agents -->
                <div class="mt-6 px-4">
                    <div class="flex items-center justify-between text-xs font-semibold text-gray-500 px-2 mb-1">
                        <span>AGENTS</span>
                        <i class="fa-solid fa-chevron-down"></i>
                    </div>
                    <div onclick="selectAgent(this)" class="sidebar-item-active flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <div class="w-5 h-5 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-md flex items-center justify-center">
                            <span class="text-white text-xs">🔬</span>
                        </div>
                        <span class="font-medium">Researcher</span>
                    </div>
                    <div onclick="selectAgent(this)" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <div class="w-5 h-5 bg-gradient-to-br from-amber-500 to-orange-500 rounded-md flex items-center justify-center">
                            <span class="text-white text-xs">📊</span>
                        </div>
                        <span class="font-medium">Analyst</span>
                    </div>
                </div>
                
                <!-- Меню -->
                <div class="mt-4 px-2 flex-1 overflow-y-auto">
                    <div class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-layer-group w-5 text-gray-500"></i>
                        <span>All agents</span>
                    </div>
                    <div class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-plus w-5 text-gray-500"></i>
                        <span>Create agent</span>
                    </div>
                    <div class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-clock-rotate-left w-5 text-gray-500"></i>
                        <span>Conversations</span>
                    </div>
                    <div class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-file-lines w-5 text-gray-500"></i>
                        <span>Pages</span>
                    </div>
                    <div class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-book w-5 text-gray-500"></i>
                        <span>Notebooks</span>
                    </div>
                    <div class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-square-plus w-5 text-gray-500"></i>
                        <span>Create</span>
                    </div>
                    <div class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-2xl text-sm cursor-pointer">
                        <i class="fa-solid fa-th-large w-5 text-gray-500"></i>
                        <span>Apps</span>
                    </div>
                </div>
                
                <!-- Нижняя часть -->
                <div class="p-4 border-t">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl"></div>
                        <div>
                            <div class="text-sm font-medium">Ваш аккаунт</div>
                            <div class="text-xs text-gray-500">Contoso Inc.</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Основная область -->
            <div class="flex-1 flex flex-col">
                
                <!-- Верхняя панель Researcher -->
                <div class="h-14 border-b flex items-center px-6 bg-white">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 bg-gradient-to-br from-violet-500 to-blue-500 rounded-2xl flex items-center justify-center shadow">
                            <span class="text-white text-2xl">🔬</span>
                        </div>
                        <div>
                            <div class="font-semibold text-lg leading-none">Researcher</div>
                            <div class="text-xs text-emerald-600">Онлайн • ИИ-исследователь</div>
                        </div>
                    </div>
                    
                    <!-- Кнопка Try Claude -->
                    <div onclick="tryClaude()" 
                         class="ml-auto flex items-center gap-2 bg-white shadow-lg shadow-blue-100 border border-gray-200 hover:border-gray-300 rounded-3xl px-5 py-1.5 cursor-pointer transition">
                        <span class="text-sm font-medium">Попробовать Claude</span>
                        <div class="w-7 h-7 bg-gradient-to-br from-purple-600 to-indigo-600 rounded-2xl flex items-center justify-center text-white text-lg">
                            🧠
                        </div>
                    </div>
                </div>
                
                <!-- Контент -->
                <div id="main-content" class="flex-1 p-6 overflow-auto bg-[#f8fafc]">
                    
                    <!-- Приветствие -->
                    <div class="max-w-2xl mx-auto text-center mb-10">
                        <div class="inline-flex items-center gap-2 bg-white shadow rounded-3xl px-5 py-2 mb-6">
                            <div class="wave-bg w-6 h-6 rounded-2xl flex items-center justify-center">
                                <span class="text-white text-xl">🔍</span>
                            </div>
                            <span class="font-semibold text-gray-700">Что вы хотите исследовать сегодня?</span>
                        </div>
                    </div>
                    
                    <!-- Поле ввода -->
                    <div class="max-w-3xl mx-auto">
                        <div id="input-container" 
                             class="bg-white border-2 border-gray-200 focus-within:border-blue-500 rounded-3xl p-2 transition">
                            <div class="flex items-center gap-2 bg-gray-50 rounded-3xl px-5 py-3">
                                <button onclick="addSources()" 
                                        class="flex items-center gap-2 text-blue-600 hover:text-blue-700 text-sm font-medium">
                                    <i class="fa-solid fa-plus"></i>
                                    <span>Sources</span>
                                </button>
                                
                                <input id="prompt-input" 
                                       onkeypress="if(event.key === 'Enter') sendPrompt()"
                                       class="flex-1 bg-transparent outline-none text-gray-700 placeholder-gray-400 text-base"
                                       placeholder="Введите запрос для исследования...">
                                
                                <button onclick="voiceInput()" 
                                        class="w-9 h-9 flex items-center justify-center text-gray-400 hover:text-gray-600 rounded-2xl hover:bg-gray-100">
                                    <i class="fa-solid fa-microphone"></i>
                                </button>
                                
                                <button onclick="sendPrompt()" 
                                        class="w-9 h-9 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl flex items-center justify-center">
                                    <i class="fa-solid fa-arrow-up"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Быстрые подсказки -->
                    <div id="suggestions" class="max-w-4xl mx-auto mt-10">
                        <div class="grid grid-cols-3 gap-4">
                            
                            <!-- Карточка 1 -->
                            <div onclick="useSuggestion(this)" 
                                 class="suggestion-card bg-white border border-gray-100 rounded-3xl p-5 cursor-pointer">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-9 h-9 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center text-xl">📋</div>
                                    <div class="font-semibold text-gray-800">Project Update</div>
                                </div>
                                <p class="text-sm text-gray-500 leading-tight">Executive status report on Project</p>
                            </div>
                            
                            <!-- Карточка 2 -->
                            <div onclick="useSuggestion(this)" 
                                 class="suggestion-card bg-white border border-gray-100 rounded-3xl p-5 cursor-pointer">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-9 h-9 bg-purple-100 text-purple-600 rounded-2xl flex items-center justify-center text-xl">📌</div>
                                    <div class="font-semibold text-gray-800">Topic Report</div>
                                </div>
                                <p class="text-sm text-gray-500 leading-tight">Update me on Topic</p>
                            </div>
                            
                            <!-- Карточка 3 -->
                            <div onclick="useSuggestion(this)" 
                                 class="suggestion-card bg-white border border-gray-100 rounded-3xl p-5 cursor-pointer">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-9 h-9 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center text-xl">👥</div>
                                    <div class="font-semibold text-gray-800">Customer Brief</div>
                                </div>
                                <p class="text-sm text-gray-500 leading-tight">Help me prepare for a meeting with Customer</p>
                            </div>
                            
                            <!-- Карточка 4 -->
                            <div onclick="useSuggestion(this)" 
                                 class="suggestion-card bg-white border border-gray-100 rounded-3xl p-5 cursor-pointer">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-9 h-9 bg-amber-100 text-amber-600 rounded-2xl flex items-center justify-center text-xl">📈</div>
                                    <div class="font-semibold text-gray-800">Market Analysis</div>
                                </div>
                                <p class="text-sm text-gray-500 leading-tight">Analyze the market position of Company</p>
                            </div>
                            
                            <!-- Карточка 5 -->
                            <div onclick="useSuggestion(this)" 
                                 class="suggestion-card bg-white border border-gray-100 rounded-3xl p-5 cursor-pointer">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-9 h-9 bg-rose-100 text-rose-600 rounded-2xl flex items-center justify-center text-xl">📅</div>
                                    <div class="font-semibold text-gray-800">Meeting Prep</div>
                                </div>
                                <p class="text-sm text-gray-500 leading-tight">Help me prepare for my meetings next week</p>
                            </div>
                            
                            <!-- Карточка 6 -->
                            <div onclick="useSuggestion(this)" 
                                 class="suggestion-card bg-white border border-gray-100 rounded-3xl p-5 cursor-pointer">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-9 h-9 bg-cyan-100 text-cyan-600 rounded-2xl flex items-center justify-center text-xl">☀️</div>
                                    <div class="font-semibold text-gray-800">Daily briefing</div>
                                </div>
                                <p class="text-sm text-gray-500 leading-tight">Show today's updates, tasks, and meetings</p>
                            </div>
                            
                        </div>
                    </div>
                    
                    <!-- Зона чата (появляется после отправки) -->
                    <div id="chat-area" class="hidden max-w-3xl mx-auto mt-8 space-y-6">
                        <!-- JS будет добавлять сообщения сюда -->
                    </div>
                </div>
                
                <!-- Нижний статус -->
                <div class="h-9 bg-white border-t flex items-center px-6 text-xs text-gray-400">
                    <div class="flex items-center gap-2">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                        Подключено к Copilot
                    </div>
                    <div class="ml-auto flex items-center gap-4 text-[10px]">
                        <span>Ctrl + K — новая тема</span>
                        <span>Esc — очистить</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Инициализация Tailwind
        function initTailwind() {
            // Уже подключен через CDN
        }
        
        // Выбор агента
        function selectAgent(el) {
            document.querySelectorAll('.sidebar-item').forEach(item => {
                item.classList.remove
